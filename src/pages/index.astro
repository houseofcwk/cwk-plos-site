---
import Base from '../layouts/Base.astro';
import HeroSection from '../components/home/HeroSection.astro';
import MissionSection from '../components/home/MissionSection.astro';
import WhatCwkDoesSection from '../components/home/WhatCwkDoesSection.astro';
import ThreeLevelsSection from '../components/home/ThreeLevelsSection.astro';
import PillarsSection from '../components/home/PillarsSection.astro';
import WorkMosaicSection from '../components/home/WorkMosaicSection.astro';
import ProductPreviewSection from '../components/home/ProductPreviewSection.astro';
import GoogleReviewsSection from '../components/home/GoogleReviewsSection.astro';
import PlayerXRaySection from '../components/PlayerXRaySection.astro';
import { sanity, getSiteSettings } from '../lib/sanity';
import { HOME_QUERY } from '../lib/queries';
import { FAQS_FALLBACK } from '../lib/seoFallbacks';

// Sanity-first; fall through to hardcoded copy when the homePage doc isn't published.
let s: any = null;
try { s = await sanity.fetch(HOME_QUERY); } catch { s = null; }
const siteSettings = await getSiteSettings();

const HARDCODED_PHRASES = [
  'partner', 'operator', 'architect', 'co-founder', 'infrastructure',
];
const HARDCODED_PILLARS = [
  { key: 'mind',   title: 'Mind',   body: 'Strategic clarity, decision frameworks, mental performance, and clearing psychological blockers that stop growth.' },
  { key: 'body',   title: 'Body',   body: 'The operational systems required for the body to be nurtured through access to nutrition and regular fitness habits.' },
  { key: 'soul',   title: 'Soul',   body: 'Legacy building, IP development, thought leadership positioning, and turning your expertise into community building.' },
  { key: 'pocket', title: 'Pocket', body: 'Revenue systems, opportunity sourcing, deal structuring, and building the financial engine that funds your vision.' },
];

const pageTitle       = s?.seo?.title       ?? 'CWK. Experience | The Sports Agent for Entrepreneurs';
const pageDescription = s?.seo?.description ?? 'CWK. is the long-term partner for entrepreneurs. We rep your career, install the operations, and manage your growth, all under one house.';
const pageOgImage     = s?.seo?.ogImage?.asset?.url ?? null;
const pageOgImageAlt  = s?.seo?.ogImage?.alt ?? null;
const pageCanonical   = s?.seo?.canonicalUrl ?? null;
const pageOgType      = s?.seo?.ogType ?? 'website';
const pageTwitterCard = s?.seo?.twitterCard ?? null;
const pageRobots      = s?.seo?.robots ?? null;

// FAQPage JSON-LD: Sanity-managed faqs, fallback to the curated 4 in seoFallbacks.
const faqs = (Array.isArray(siteSettings?.faqs) && siteSettings.faqs.length > 0)
  ? siteSettings.faqs.filter((f: any) => f?.question && f?.answer)
  : FAQS_FALLBACK;
const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f: { question: string; answer: string }) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};
const heroEyebrow     = s?.heroEyebrow      ?? 'Personal Leverage OS';
const heroHeadline    = s?.heroHeadline     ?? 'CWK. is like a';
const wordPhrases: string[] = (Array.isArray(s?.wordFlipPhrases) && s.wordFlipPhrases.length > 0)
  ? s.wordFlipPhrases : HARDCODED_PHRASES;
const heroCtaLabel    = s?.heroCta?.label   ?? 'Join Waitlist';
const pillars = (Array.isArray(s?.pillars) && s.pillars.length > 0) ? s.pillars : HARDCODED_PILLARS;
const googleReviews = Array.isArray(s?.googleReviews) ? s.googleReviews : null;
const googleReviewsAggregateRating = typeof s?.googleReviewsAggregateRating === 'number' ? s.googleReviewsAggregateRating : null;
const googleReviewsTotalCount = typeof s?.googleReviewsTotalCount === 'number' ? s.googleReviewsTotalCount : null;
---

<Base
  title={pageTitle}
  description={pageDescription}
  ogImage={pageOgImage}
  ogImageAlt={pageOgImageAlt}
  canonical={pageCanonical}
  ogType={pageOgType}
  twitterCard={pageTwitterCard}
  robots={pageRobots}
  extraJsonLd={faqJsonLd}
>
  <HeroSection
    eyebrow={heroEyebrow}
    headline={heroHeadline}
    phrases={wordPhrases}
    ctaLabel={heroCtaLabel}
  />
  <MissionSection />
  <WhatCwkDoesSection />
  <ThreeLevelsSection />
  <PillarsSection pillars={pillars} />
  <WorkMosaicSection />
  <GoogleReviewsSection
    reviews={googleReviews}
    aggregateRating={googleReviewsAggregateRating}
    totalCount={googleReviewsTotalCount}
  />
  <ProductPreviewSection />
  <PlayerXRaySection />
</Base>
