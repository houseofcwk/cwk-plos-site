---
import Base from '../layouts/Base.astro';
import PortableText from '../components/PortableText.astro';
import { sanity } from '../lib/sanity';
import { SIDE_QUESTS_QUERY } from '../lib/queries';

let s: any = null;
try { s = await sanity.fetch(SIDE_QUESTS_QUERY); } catch { s = null; }

const heroEyebrow  = s?.heroEyebrow  ?? 'Side Quests';
const heroHeadline = s?.heroHeadline ?? 'Welcome to my Side Quests.';

const pageTitle = s?.seo?.title ?? 'Side Quests — CWK. Experience';
const pageDescription = s?.seo?.description ?? 'Short, self-initiated projects that showcase range, curiosity, and execution outside of core client work.';
---

<Base
  title={pageTitle}
  description={pageDescription}
>
  <!-- ── Hero ──────────────────────────────────────────────── -->
  <section class="sq-hero">
    <div class="sq-hero-inner">
      <span class="eyebrow fade-up">{heroEyebrow}</span>
      <h1 class="fade-up fade-up-delay-1">{heroHeadline}</h1>
      {!s?.body && (
        <p class="hero-sub fade-up fade-up-delay-2">
          Side quests are short, self-initiated projects that showcase range, curiosity, and execution outside of core client work.
        </p>
      )}
    </div>
  </section>

  {s?.body ? (
    <section class="section body-section">
      <div class="section-inner">
        <div class="pt-body"><PortableText value={s.body} /></div>
      </div>
    </section>
  ) : (
  <>
  <!-- ── Quest Grid ────────────────────────────────────────── -->
  <section class="section">
    <div class="section-inner">
      <div class="quest-grid">

        <!-- Quest 1: Vending Machine -->
        <article class="glass-card quest-card fade-up">
          <div class="quest-header">
            <span class="tag">2025</span>
          </div>
          <h3>Experiential Content Vending Machine</h3>
          <p>An experiential installation exploring content creation as a physical, real-world interaction.</p>
        </article>

        <!-- Quest 2: Podcast -->
        <article class="glass-card quest-card fade-up fade-up-delay-1">
          <div class="quest-header">
            <span class="tag tag-purple">2021–2022</span>
          </div>
          <h3>Life Lessons of a Creative Entrepreneur Podcast</h3>
          <p>A self-hosted podcast exploring entrepreneurship through the creative lens.</p>
        </article>

        <!-- Quest 3: Keep Austin Voting -->
        <article class="glass-card quest-card fade-up fade-up-delay-2">
          <div class="quest-header">
            <span class="tag tag-pink">2020</span>
          </div>
          <h3>Keep Austin Voting</h3>
          <p>A civic engagement campaign blending creative production with community outreach and voter activation in Austin, TX.</p>
          <div class="quest-links">
            <a href="https://www.youtube.com/@keepaustinvoting8835" target="_blank" rel="noopener noreferrer" class="quest-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
              YouTube
            </a>
            <a href="https://www.instagram.com/keepaustinvoting_/" target="_blank" rel="noopener noreferrer" class="quest-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              Instagram
            </a>
          </div>
          <div class="quest-credits">
            <p class="credits-label">Credits</p>
            <ul class="credits-list">
              <li><span class="credit-role">Hosts</span> Raasin McIntosh &amp; Kris San</li>
              <li><span class="credit-role">Produced by</span> Sam Needham &amp; Kris San</li>
              <li><span class="credit-role">Creative Team</span> Giovanni Dueña, Casey Alfstad, Hanna Marie, Micalah Jones</li>
            </ul>
          </div>
        </article>

        <!-- Quest 4: Almost Real Things -->
        <article class="glass-card quest-card fade-up fade-up-delay-3">
          <div class="quest-header">
            <span class="tag tag-amber">2021–2023</span>
          </div>
          <h3>Almost Real Things Advisory Board</h3>
          <p>Advisory board member contributing strategic creative direction to one of Austin's most inventive cultural publications.</p>
          <div class="quest-links">
            <a href="https://almostrealthings.com/" target="_blank" rel="noopener noreferrer" class="quest-link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
              almostrealthings.com
            </a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ── Honorable Mentions ────────────────────────────────── -->
  <section class="section">
    <div class="section-inner">
      <div class="divider"></div>
      <div class="honorable-mentions">
        <span class="eyebrow">Honorable Mentions</span>
        <p>
          Beyond these features, a range of smaller experiments, collabs, and creative detours have contributed to the larger body of work — each one a lesson, a connection, or a proof of concept.
        </p>
      </div>
    </div>
  </section>
  </>
  )}

  <!-- ── CTA ───────────────────────────────────────────────── -->
  <section class="section cta-section">
    <div class="section-inner" style="text-align:center;">
      <a href="/work" class="btn btn-ghost">See The Full Work →</a>
    </div>
  </section>
</Base>

<style>
  /* Hero */
  .sq-hero {
    padding-top: 144px;
    padding-bottom: 64px;
    padding-left: 24px;
    padding-right: 24px;
    text-align: center;
  }

  .sq-hero-inner {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .sq-hero-inner h1 {
    margin: 14px 0 20px;
  }

  .hero-sub {
    font-size: 16px;
    color: var(--muted);
    max-width: 480px;
    line-height: 1.65;
  }

  /* Quest grid */
  .quest-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 8px;
  }

  .quest-card {
    padding: 28px 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .quest-header {
    display: flex;
    align-items: center;
    justify-content: flex-start;
  }

  .quest-card h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    line-height: 1.3;
  }

  .quest-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
  }

  /* External links */
  .quest-links {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }

  .quest-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    color: var(--cyan);
    border: 1px solid rgba(0, 229, 255, 0.2);
    background: rgba(0, 229, 255, 0.06);
    padding: 6px 12px;
    border-radius: 6px;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .quest-link:hover {
    background: rgba(0, 229, 255, 0.12);
    border-color: rgba(0, 229, 255, 0.4);
    opacity: 1;
  }

  /* Credits */
  .quest-credits {
    margin-top: 4px;
    padding-top: 14px;
    border-top: 1px solid var(--gb);
  }

  .credits-label {
    font-size: 10px !important;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim) !important;
    margin-bottom: 8px;
  }

  .credits-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .credits-list li {
    font-size: 12px;
    color: var(--muted);
    line-height: 1.5;
  }

  .credit-role {
    color: var(--dim);
    font-size: 11px;
    font-weight: 600;
    margin-right: 4px;
  }

  /* Honorable Mentions */
  .honorable-mentions {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-width: 560px;
  }

  .honorable-mentions p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
  }

  /* CTA */
  .cta-section {
    padding-bottom: 40px;
  }

  /* Portable Text body (Sanity-authored) */
  .body-section .section-inner {
    max-width: 680px;
  }
  .pt-body :global(h2) {
    font-size: clamp(20px, 2.8vw, 26px);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    margin: 32px 0 12px;
  }
  .pt-body :global(h2:first-child) { margin-top: 0; }
  .pt-body :global(h3) {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    margin: 24px 0 10px;
  }
  .pt-body :global(p) {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 14px;
  }
  .pt-body :global(ul) {
    list-style: none;
    padding-left: 0;
    margin: 0 0 14px;
  }
  .pt-body :global(li) {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.65;
    padding-left: 20px;
    position: relative;
    margin-bottom: 8px;
  }
  .pt-body :global(li::before) {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--cyan);
    font-size: 11px;
    top: 3px;
  }
  .pt-body :global(strong) { color: var(--text); font-weight: 600; }
  .pt-body :global(a)      { color: var(--cyan); }

  /* Responsive */
  @media (max-width: 680px) {
    .quest-grid {
      grid-template-columns: 1fr;
    }

    .sq-hero {
      padding-top: 112px;
      padding-bottom: 48px;
    }
  }
</style>
