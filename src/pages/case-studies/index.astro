---
import Base from '../../layouts/Base.astro';
import PlayerXRaySection from '../../components/PlayerXRaySection.astro';
import { sanity, urlFor } from '../../lib/sanity';
import { CASE_LIST_QUERY } from '../../lib/queries';
import { CASE_STUDIES, isVisibleSlug, visibleOrderIndex, type CardSurface } from '../../data/caseStudies';

let sanityCases: any[] | null = null;
try {
  const result = await sanity.fetch(CASE_LIST_QUERY);
  sanityCases = Array.isArray(result) && result.length > 0 ? result : null;
} catch {
  sanityCases = null;
}

interface CardEntry {
  slug: string;
  client: string;
  category: string;
  medium: string;
  cardSurface: CardSurface;
  cardAccent: string;
  cardImage?: string;
  cardImageAlt?: string;
  cardThumbnail?: string;
  cardDescription: string;
  cardStat: { num: string; label: string };
}

function fromSanity(c: any): CardEntry {
  let cardImage: string | undefined;
  if (c.cardImage?.asset) {
    try {
      cardImage = urlFor(c.cardImage).width(900).auto('format').url();
    } catch {
      cardImage = undefined;
    }
  }
  let cardThumbnail: string | undefined;
  if (c.cardThumbnail?.asset) {
    try {
      cardThumbnail = urlFor(c.cardThumbnail).width(900).auto('format').url();
    } catch {
      cardThumbnail = undefined;
    }
  }
  // Per-field fallback: if Sanity is missing this study's image, use the
  // hardcoded entry so the listing never renders empty placeholders for
  // studies that have static art.
  const staticEntry = CASE_STUDIES.find((s) => s.slug === c.slug);
  return {
    slug: c.slug,
    client: c.client ?? staticEntry?.client ?? '',
    category: c.category ?? staticEntry?.category ?? '',
    medium: c.medium ?? staticEntry?.medium ?? '',
    cardSurface: (c.cardSurface ?? staticEntry?.cardSurface ?? 'glass') as CardSurface,
    cardAccent: c.cardAccent ?? staticEntry?.cardAccent ?? '#00E5FF',
    cardImage: cardImage ?? staticEntry?.cardImage,
    cardImageAlt: c.cardImage?.alt ?? staticEntry?.cardImageAlt ?? c.client ?? '',
    cardThumbnail: cardThumbnail ?? staticEntry?.cardThumbnail,
    cardDescription: c.cardDescription ?? staticEntry?.cardDescription ?? '',
    cardStat: {
      num: c.cardStat?.num ?? staticEntry?.cardStat?.num ?? '',
      label: c.cardStat?.label ?? staticEntry?.cardStat?.label ?? '',
    },
  };
}

const cards: CardEntry[] = (sanityCases
  ? sanityCases.map(fromSanity)
  : CASE_STUDIES.map((c) => ({
      slug: c.slug,
      client: c.client,
      category: c.category,
      medium: c.medium,
      cardSurface: c.cardSurface,
      cardAccent: c.cardAccent,
      cardImage: c.cardImage,
      cardImageAlt: c.cardImageAlt,
      cardThumbnail: c.cardThumbnail,
      cardDescription: c.cardDescription,
      cardStat: c.cardStat,
    }))
)
  .filter((c) => isVisibleSlug(c.slug))
  .sort((a, b) => visibleOrderIndex(a.slug) - visibleOrderIndex(b.slug));

const pageTitle = 'Case Studies | CWK. Experience';
const pageDescription = 'Step into the worlds built by CWK. Real brands. Immersive impact. A portfolio of long-term partnerships across podcasts, non-profits, creative founders, and the CWK platform itself.';
---

<Base title={pageTitle} description={pageDescription}>
  <!-- ── Hero ────────────────────────────────────────────────── -->
  <section class="cs-hero">
    <div class="cs-hero-inner">
      <h1 class="cs-hero-title fade-up">Real brands. <span class="cs-hero-accent">Immersive impact.</span></h1>
      <p class="cs-hero-sub fade-up fade-up-delay-1">Step into the worlds built by CWK.</p>
    </div>
  </section>

  <!-- ── Grid ───────────────────────────────────────────────── -->
  <section id="worlds" class="cs-grid-section">
    <div class="cs-grid-inner">
      <div class="cs-grid">
        {cards.map((c, i) => (
          <a
            href={`/case-studies/${c.slug}`}
            class="cs-card reveal-card"
            style={`--reveal-i:${i}`}
          >
            <span class="cs-card-eyebrow">{c.category}</span>
            <h2 class="cs-card-title">{c.client}</h2>

            {(c.cardThumbnail ?? c.cardImage) ? (
              <div class="cs-card-image">
                <img src={c.cardThumbnail ?? c.cardImage} alt={c.cardImageAlt ?? c.client} loading="lazy" decoding="async" />
              </div>
            ) : (
              <div class="cs-card-image cs-card-image--empty" aria-hidden="true">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="9"/><path d="M12 3v18M3 12h18"/>
                </svg>
              </div>
            )}

            <span class="cs-card-medium">{c.medium}</span>
            <p class="cs-card-desc">{c.cardDescription}</p>

            <div class="cs-card-stat">
              <span class="cs-card-stat-num">{c.cardStat.num}</span>
              <span class="cs-card-stat-label">{c.cardStat.label}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <PlayerXRaySection />
</Base>

<style>
  /* ── Hero ─────────────────────────────────────────────────── */
  .cs-hero {
    padding: 144px 24px 56px;
    text-align: center;
  }
  .cs-hero-inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
  }
  .cs-hero-title {
    font-size: clamp(34px, 5.4vw, 56px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text);
    margin: 0;
  }
  .cs-hero-accent {
    background: linear-gradient(90deg, #00E5FF, #7B61FF 60%, #FB3079);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .cs-hero-sub {
    margin: 0;
    color: var(--muted);
    font-size: clamp(15px, 1.5vw, 17px);
    line-height: 1.6;
  }
  /* ── Grid ─────────────────────────────────────────────────── */
  .cs-grid-section {
    padding: 32px 24px 96px;
  }
  .cs-grid-inner {
    max-width: 1240px;
    margin: 0 auto;
  }
  .cs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(18px, 2vw, 28px);
  }
  @media (max-width: 960px) {
    .cs-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .cs-grid { grid-template-columns: 1fr; }
  }

  /* ── Card base ───────────────────────────────────────────── */
  .cs-card {
    position: relative;
    isolation: isolate;
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 22px 22px 24px;
    border-radius: 18px;
    text-decoration: none;
    color: var(--text);
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background:
      radial-gradient(120% 80% at 0% 0%, rgba(0, 229, 255, 0.05), transparent 55%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.035) 0%, rgba(255, 255, 255, 0.01) 100%);
    transition: transform 0.4s cubic-bezier(0.22,1,0.36,1), border-color 0.3s ease, box-shadow 0.4s ease, background 0.3s ease;
    min-height: 460px;
  }
  .cs-card:hover {
    transform: translateY(-4px);
    border-color: rgba(0, 229, 255, 0.28);
    box-shadow:
      0 18px 46px rgba(0, 0, 0, 0.55),
      0 0 0 1px rgba(0, 229, 255, 0.08);
  }

  .cs-card-eyebrow {
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    color: rgba(255,255,255,0.62);
  }

  .cs-card-title {
    margin: 0;
    font-size: clamp(22px, 2vw, 28px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .cs-card-image {
    aspect-ratio: 16 / 10;
    border-radius: 12px;
    overflow: hidden;
    background: rgba(0,0,0,0.35);
    border: 1px solid rgba(255,255,255,0.06);
    margin-top: 4px;
  }
  .cs-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .cs-card-image--empty {
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.18);
  }

  .cs-card-medium {
    font-size: 9.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    color: rgba(255,255,255,0.55);
    margin-top: 2px;
  }

  .cs-card-desc {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255,255,255,0.72);
    flex: 1;
  }

  .cs-card-stat {
    display: flex;
    align-items: baseline;
    gap: 10px;
    padding-top: 14px;
    margin-top: auto;
    border-top: 1px solid rgba(255,255,255,0.07);
  }
  .cs-card-stat-num {
    font-size: 28px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--cyan);
  }
  .cs-card-stat-label {
    font-size: 12px;
    letter-spacing: 0.05em;
    color: rgba(255,255,255,0.62);
  }

  @media (prefers-reduced-motion: reduce) {
    .cs-card { transition: none; }
  }
</style>
