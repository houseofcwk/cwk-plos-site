  .pu-row-select:hover { background: color-mix(in srgb, var(--accent) 12%, transparent); transform: translateY(-1px); }
  .pu-row-select-on { display: none; }
  .pu-row.is-selected .pu-row-select {
    background: var(--accent);
    color: #0a0e1a;
  }
  .pu-row.is-selected .pu-row-select-add { display: none; }
  .pu-row.is-selected .pu-row-select-on { display: inline; }

  /* Tier list (Digital Home) */
  .pu-tier-list {
    list-style: none;
    margin: 0 0 14px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .pu-tier {
    padding: 12px 14px;
    border: 1px solid var(--gb);
    border-radius: 10px;
    background: rgba(0, 0, 0, 0.2);
  }
  .pu-tier header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 4px;
  }
  .pu-tier header strong { color: var(--text); font-size: 13px; }
  .pu-tier header span {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .pu-tier p { margin: 0; font-size: 12.5px; color: var(--muted); line-height: 1.5; }
  .pu-tier-price { display: inline-block; margin-top: 6px; font-size: 13px; font-weight: 700; color: var(--accent); }

  /* Bundle card */
  .pu-bundle-card {
    padding: 28px;
    border-radius: 18px;
    border: 1px solid color-mix(in srgb, var(--accent) 32%, var(--gb));
    background:
      radial-gradient(80% 60% at 100% 0%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 60%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .pu-bundle-card.is-selected {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 28%, transparent);
  }
  .pu-bundle-card header {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 18px;
  }
  .pu-bundle-tag {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 700;
  }
  .pu-bundle-card header h3 {
    margin: 0;
    font-size: clamp(22px, 2.5vw, 28px);
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .pu-bundle-card header p { margin: 0; color: var(--muted); }

  .pu-bundle-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 26px;
    margin-bottom: 16px;
  }
  .pu-bundle-cols h4 {
    margin: 0 0 8px;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 700;
  }
  .pu-bundle-cols ol,
  .pu-bundle-cols ul {
    margin: 0;
    padding-left: 18px;
    color: var(--muted);
    line-height: 1.65;
    font-size: 13.5px;
  }

  .pu-bundle-deposit {
    margin: 0 0 18px;
    padding: 12px 14px;
    border: 1px dashed color-mix(in srgb, var(--accent) 40%, var(--gb));
    border-radius: 10px;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.55;
  }
  .pu-bundle-deposit strong { color: var(--accent); }

  .pu-bundle-card footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    flex-wrap: wrap;
    padding-top: 16px;
    border-top: 1px solid color-mix(in srgb, var(--accent) 25%, var(--gb));
  }
  .pu-bundle-price-block { display: flex; flex-direction: column; gap: 2px; }
  .pu-bundle-price-label {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 700;
  }
  .pu-bundle-price {
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--accent);
    line-height: 1;
  }
  .pu-bundle-individual {
    margin-top: 2px;
    font-size: 11.5px;
    color: var(--dim);
  }
  .pu-bundle-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 24px;
    border-radius: 100px;
    border: 0;
    background: var(--accent);
    color: #0a0e1a;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    font: inherit;
    font-weight: 700;
    transition: filter 0.2s ease, transform 0.15s ease;
  }
  .pu-bundle-cta:hover { filter: brightness(1.1); transform: translateY(-1px); }
  .pu-bundle-cta-on { display: none; }
  .pu-bundle-card.is-selected .pu-bundle-cta {
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--accent);
  }
  .pu-bundle-card.is-selected .pu-bundle-cta-add { display: none; }
  .pu-bundle-card.is-selected .pu-bundle-cta-on { display: inline; }

  /* Stack panel */
  .pu-panel--stack {
    --accent: #7B61FF;
  }
  .pu-stack-card {
    padding: clamp(28px, 4vw, 44px);
    border-radius: 22px;
    border: 1px solid rgba(123, 97, 255, 0.32);
    background:
      radial-gradient(60% 60% at 50% 0%, rgba(0, 229, 255, 0.10), transparent 60%),
      radial-gradient(50% 60% at 80% 50%, rgba(123, 97, 255, 0.10), transparent 60%),
      radial-gradient(50% 60% at 20% 50%, rgba(251, 48, 121, 0.10), transparent 60%);
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }
  .pu-stack-card.is-selected {
    border-color: var(--cyan);
    box-shadow: 0 0 0 1px rgba(0, 229, 255, 0.32);
  }
  .pu-stack-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 5px 12px;
    border: 1px solid rgba(0, 229, 255, 0.28);
    border-radius: 100px;
    background: rgba(0, 229, 255, 0.06);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cyan);
    font-weight: 800;
  }
  .pu-stack-headline {
    margin: 16px 0 10px;
    font-size: clamp(24px, 3.4vw, 36px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--text);
    max-width: 760px;
  }
  .pu-stack-lede {
    margin: 0 0 28px;
    color: var(--muted);
    max-width: 600px;
    line-height: 1.6;
    font-size: 15.5px;
  }

  /* 3-card phase timeline */
  .pu-stack-phases {
    list-style: none;
    margin: 0 0 28px;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }
  .pu-stack-phase {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 18px 18px 20px;
    border: 1px solid var(--gb);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.03);
    text-align: left;
  }
  .pu-stack-phase-num {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cyan);
    font-weight: 800;
  }
  .pu-stack-phase-window {
    font-size: 12.5px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 700;
  }
  .pu-stack-phase-name {
    margin: 2px 0 0;
    font-size: 17px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--text);
    line-height: 1.2;
  }
  .pu-stack-phase-desc {
    margin: 2px 0 0;
    font-size: 13.5px;
    color: var(--muted);
    line-height: 1.5;
  }
  .pu-stack-phase-clock {
    margin-top: auto;
    padding-top: 10px;
    border-top: 1px dashed rgba(255, 255, 255, 0.08);
    font-size: 11.5px;
    color: var(--dim);
    line-height: 1.45;
    font-style: italic;
  }

  /* Summary card: cost breakdown + total + CTA */
  .pu-stack-summary {
    padding: 22px 24px 24px;
    border: 1px solid var(--gb);
    border-radius: 18px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.01));
  }
  .pu-stack-breakdown {
    list-style: none;
    margin: 0 0 22px;
    padding: 0 0 18px;
    border-bottom: 1px solid var(--gb);
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }
  .pu-stack-breakdown li {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-left: 14px;
    border-left: 2px solid rgba(123, 97, 255, 0.32);
  }
  .pu-stack-breakdown li:nth-child(1) { border-left-color: rgba(0, 229, 255, 0.45); }
  .pu-stack-breakdown li:nth-child(2) { border-left-color: rgba(123, 97, 255, 0.45); }
  .pu-stack-breakdown li:nth-child(3) { border-left-color: rgba(251, 48, 121, 0.45); }
  .pu-stack-breakdown-label {
    font-size: 10.5px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 800;
  }
  .pu-stack-breakdown-num {
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .pu-stack-summary-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
  }
  .pu-stack-total {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
  }
  .pu-stack-total-label {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 800;
  }
  .pu-stack-total-num {
    font-size: clamp(40px, 6vw, 56px);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    background: linear-gradient(90deg, #00E5FF, #7B61FF, #FB3079);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .pu-stack-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 16px 28px;
    border: 0;
    border-radius: 100px;
    background: linear-gradient(90deg, #00E5FF, #7B61FF, #FB3079);
    color: #0a0e1a;
    font-size: 14.5px;
    font-weight: 800;
    letter-spacing: 0.01em;
    cursor: pointer;
    font: inherit;
    font-weight: 800;
    box-shadow: 0 12px 30px rgba(123, 97, 255, 0.28);
    transition: filter 0.2s ease, transform 0.15s ease, box-shadow 0.25s ease;
  }
  .pu-stack-cta:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
    box-shadow: 0 16px 36px rgba(123, 97, 255, 0.36);
  }
  .pu-stack-cta-on { display: none; }
  .pu-stack-card.is-selected .pu-stack-cta {
    background: transparent;
    border: 1px solid var(--cyan);
    color: var(--cyan);
    box-shadow: none;
  }
  .pu-stack-card.is-selected .pu-stack-cta-add { display: none; }
  .pu-stack-card.is-selected .pu-stack-cta-on { display: inline; }

  @media (max-width: 760px) {
    .pu-stack-phases { grid-template-columns: 1fr; }
    .pu-stack-breakdown { grid-template-columns: 1fr; gap: 12px; }
    .pu-stack-summary-foot { flex-direction: column; align-items: stretch; }
    .pu-stack-cta { justify-content: center; }
  }

  /* ── Cart bar (collapsed) ──────────────────────────────── */
  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  .pu-cart-bar {
    position: fixed;
    left: 50%;
    bottom: 20px;
    z-index: 100;
    transform: translate(-50%, calc(100% + 30px));
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 10px 10px 10px 16px;
    width: min(520px, calc(100vw - 32px));
    border: 0;
    border-radius: 100px;
    background:
      linear-gradient(rgba(11, 14, 24, 0.96), rgba(11, 14, 24, 0.96)) padding-box,
      linear-gradient(120deg, #FB3079 0%, #7B61FF 50%, #00E5FF 100%) border-box;
    border: 1.5px solid transparent;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    box-shadow:
      0 18px 50px rgba(0, 0, 0, 0.6),
      0 0 24px rgba(251, 48, 121, 0.18),
      0 0 0 1px rgba(255, 255, 255, 0.04) inset;
    color: var(--text);
    font: inherit;
    cursor: pointer;
    opacity: 0;
    transition: transform 0.45s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.3s ease, box-shadow 0.3s ease, filter 0.2s ease;
  }
  .pu-cart-bar.is-visible {
    transform: translate(-50%, 0);
    opacity: 1;
  }
  .pu-cart-bar:hover {
    filter: brightness(1.04);
    box-shadow:
      0 22px 60px rgba(0, 0, 0, 0.65),
      0 0 32px rgba(251, 48, 121, 0.28),
      0 0 0 1px rgba(255, 255, 255, 0.06) inset;
  }
  .pu-cart-bar:focus-visible {
    outline: 2px solid var(--pink);
    outline-offset: 3px;
  }
  .pu-cart-bar-icon {
    width: 32px; height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: linear-gradient(135deg, rgba(251, 48, 121, 0.18), rgba(123, 97, 255, 0.18));
    border: 1px solid rgba(255, 255, 255, 0.10);
    color: #F2B53A;
    font-size: 16px;
    flex-shrink: 0;
  }
  .pu-cart-bar-meta {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    min-width: 0;
  }
  .pu-cart-bar-count {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 700;
  }
  .pu-cart-bar-total {
    font-size: 17px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--text);
    line-height: 1;
  }
  .pu-cart-bar-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    border-radius: 100px;
    background: linear-gradient(90deg, #00E5FF, #7B61FF);
    color: #0a0e1a;
    font-size: 12.5px;
    font-weight: 800;
    letter-spacing: 0.01em;
    flex-shrink: 0;
  }
  .pu-cart-bar-cta svg { flex-shrink: 0; }

  /* ── Cart dialog (expanded) ────────────────────────────── */
  .pu-cart-dialog {
    width: min(520px, calc(100vw - 32px));
    max-width: 520px;
    max-height: min(720px, calc(100vh - 48px));
    margin: auto;
    padding: 0;
    border: 1px solid var(--gb);
    border-radius: 18px;
    background: rgba(11, 14, 24, 0.96);
    color: var(--text);
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.6);
  }
  .pu-cart-dialog::backdrop {
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .pu-cart-dialog[open] {
    animation: pu-cart-rise 0.32s cubic-bezier(0.22, 1, 0.36, 1) both;
  }
  @keyframes pu-cart-rise {
    from { opacity: 0; transform: translateY(12px) scale(0.98); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .pu-cart-dialog-inner {
    display: flex;
    flex-direction: column;
    max-height: inherit;
    padding: 20px 22px 22px;
    gap: 14px;
  }
  .pu-cart-dialog-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--gb);
  }
  .pu-cart-dialog-eyebrow {
    display: block;
    font-size: 10.5px;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--pink);
    font-weight: 800;
  }
  .pu-cart-dialog-count {
    display: block;
    margin-top: 6px;
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--text);
    line-height: 1.1;
  }
  .pu-cart-dialog-close {
    width: 36px; height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--gb);
    border-radius: 50%;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    flex-shrink: 0;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .pu-cart-dialog-close:hover {
    color: var(--text);
    border-color: var(--pink);
    background: rgba(251, 48, 121, 0.08);
  }

  /* List/items shared by the dialog */
  .pu-tray-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    overflow-y: auto;
    flex: 1;
  }
  .pu-tray-item {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 14px;
    align-items: center;
    padding: 14px 14px 14px 16px;
    border: 1px solid var(--gb);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.025);
    animation: pu-tray-in 0.25s ease both;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .pu-tray-item:hover {
    border-color: var(--gb2);
    background: rgba(255, 255, 255, 0.04);
  }
  @keyframes pu-tray-in {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .pu-tray-item-meta {
    display: flex;
    flex-direction: column;
    gap: 4px;
    min-width: 0;
  }
  .pu-tray-item-name {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    line-height: 1.35;
    letter-spacing: -0.005em;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    word-break: break-word;
  }
  .pu-tray-item-price {
    font-size: 13.5px;
    font-weight: 800;
    letter-spacing: -0.01em;
    color: var(--cyan);
    line-height: 1;
  }
  .pu-tray-item-remove {
    width: 30px; height: 30px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 1px solid var(--gb);
    color: var(--dim);
    line-height: 1;
    cursor: pointer;
    border-radius: 50%;
    flex-shrink: 0;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }
  .pu-tray-item-remove:hover {
    color: var(--pink);
    border-color: var(--pink);
    background: rgba(251, 48, 121, 0.08);
  }

  .pu-cart-dialog-foot {
    border-top: 1px solid var(--gb);
    padding-top: 14px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .pu-tray-total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .pu-tray-total > span:first-child {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .pu-tray-total > span:last-child {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -0.025em;
    color: var(--text);
  }
  .pu-tray-deposit {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 12.5px;
    padding: 10px 12px;
    border-radius: 10px;
    background: rgba(0, 229, 255, 0.06);
    border: 1px solid rgba(0, 229, 255, 0.18);
    color: var(--muted);
  }
  .pu-tray-deposit > span:last-child {
    font-weight: 800;
    color: var(--cyan);
  }
  .pu-tray-checkout {
    text-align: center;
    padding: 15px 16px;
    border-radius: 12px;
    background: linear-gradient(90deg, #00E5FF, #7B61FF);
    color: #0a0e1a;
    font-size: 14px;
    font-weight: 800;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: filter 0.2s ease, transform 0.15s ease;
  }
  .pu-tray-checkout:hover { filter: brightness(1.1); transform: translateY(-1px); }
  .pu-tray-clear {
    padding: 10px;
    background: transparent;
    border: 1px solid var(--gb);
    color: var(--dim);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-radius: 10px;
    cursor: pointer;
    font: inherit;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .pu-tray-clear:hover { color: var(--pink); border-color: var(--pink); }

  @media (max-width: 640px) {
    .pu-cart-bar {
      bottom: 14px;
      padding: 9px 9px 9px 14px;
      gap: 10px;
    }
    .pu-cart-bar-cta-text { display: none; }
    .pu-cart-bar-cta { padding: 10px 12px; }

    .pu-cart-dialog {
      width: 100vw;
      max-width: 100vw;
      max-height: 100vh;
