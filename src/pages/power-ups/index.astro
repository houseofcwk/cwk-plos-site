---
import Base from '../../layouts/Base.astro';
import PlayerXRaySection from '../../components/PlayerXRaySection.astro';
import {
  POWER_UPS,
  BUNDLES,
  CATEGORY_META,
  COMPLETE_STACK_PRICE,
  type PowerUpCategory,
} from '../../data/powerUps';

const pageTitle = 'Power Ups | Level 2 — CWK. Experience';
const pageDescription = 'Level up one Power Up at a time. 21 single-focus transformation tools across Identity, Systems, and Presence. Three bundles. One complete business in 90 days.';

const CATEGORIES: PowerUpCategory[] = ['identity', 'systems', 'presence'];
const byCategory = (cat: PowerUpCategory) => POWER_UPS.filter((pu) => pu.category === cat);
const bundleFor  = (cat: PowerUpCategory) => BUNDLES.find((b) => b.category === cat)!;

// Quiz definition. Each option points at a category. Most-frequent wins; ties
// fall back to the first-listed track (Identity).
const QUIZ = [
  {
    q: 'Where are you most stuck right now?',
    options: [
      { text: "I can't explain what I do clearly. People don't get it.", track: 'identity' as const },
      { text: 'Sales conversations feel inconsistent. Close rate is up and down.', track: 'systems' as const },
      { text: "I'm invisible in my market. People don't know I exist.", track: 'presence' as const },
    ],
  },
  {
    q: "What's your biggest day-to-day pain?",
    options: [
      { text: 'Wrong-fit clients keep slipping through. I keep saying yes to the wrong people.', track: 'identity' as const },
      { text: 'Deals die because nothing is tracked. I forget to follow up.', track: 'systems' as const },
      { text: 'I post, I show up, but nothing compounds. The reach is flat.', track: 'presence' as const },
    ],
  },
  {
    q: 'What would unblock you in 30 days?',
    options: [
      { text: 'A locked positioning, voice, and visual identity I can stand on.', track: 'identity' as const },
      { text: 'A working sales engine that runs without me as the bottleneck.', track: 'systems' as const },
      { text: 'A consistent presence on the platforms my audience lives on.', track: 'presence' as const },
    ],
  },
];
---

<Base title={pageTitle} description={pageDescription}>
  <!-- ── Hero ────────────────────────────────────────────── -->
  <section class="pu-hero">
    <div class="pu-hero-inner">
      <span class="pu-eyebrow fade-up">Level 2 · Power Ups</span>
      <h1 class="pu-hero-headline fade-up fade-up-delay-1">
        Level up <em>one Power Up at a time.</em>
      </h1>
      <p class="pu-hero-sub fade-up fade-up-delay-2">
        Pick your track. Select what you need. Build the ecosystem piece by piece, or take the whole box and move faster.
      </p>
      <div class="pu-hero-actions fade-up fade-up-delay-3">
        <a href="#quiz" class="pu-hero-cta">Find my track →</a>
        <a href="#tracks" class="pu-hero-cta-secondary">Skip the quiz</a>
      </div>
    </div>
  </section>

  <!-- ── Quiz ────────────────────────────────────────────── -->
  <section id="quiz" class="pu-quiz" aria-labelledby="quiz-heading">
    <div class="pu-quiz-inner">
      <header class="pu-quiz-header">
        <span class="pu-quiz-tag">⚡ Three questions</span>
        <h2 id="quiz-heading">Where do you start?</h2>
        <p>Answer three quick questions. We'll point you at the track that matches what you actually need right now.</p>
      </header>

      <div class="pu-quiz-stage" data-quiz>
        {QUIZ.map((step, i) => (
          <div class={`pu-quiz-step ${i === 0 ? 'is-active' : ''}`} data-step={i}>
            <div class="pu-quiz-progress" aria-hidden="true">
              <span class="pu-quiz-progress-num">{i + 1}/{QUIZ.length}</span>
              <span class="pu-quiz-progress-bar"><span style={`width:${((i + 1) / QUIZ.length) * 100}%`}></span></span>
            </div>
            <h3>{step.q}</h3>
            <ul>
              {step.options.map((opt) => (
                <li>
                  <button type="button" data-quiz-pick={opt.track}>
                    <span>{opt.text}</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                    </svg>
                  </button>
                </li>
              ))}
            </ul>
          </div>
        ))}

        <div class="pu-quiz-step pu-quiz-result" data-step="result">
          <span class="pu-quiz-result-tag">Your match</span>
          <h3 data-quiz-result-title>Start with Identity.</h3>
          <p data-quiz-result-blurb>Lock who you are, what you stand for, and how you sound. Everything else is built on this.</p>
          <div class="pu-quiz-result-actions">
            <button type="button" data-quiz-go class="pu-quiz-go">See the recommended track →</button>
            <button type="button" data-quiz-restart class="pu-quiz-restart">Restart quiz</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Tracks ──────────────────────────────────────────── -->
  <section id="tracks" class="pu-tracks">
    <div class="pu-tracks-inner">
      <!-- Tab nav -->
      <nav class="pu-tab-nav" role="tablist" aria-label="Power Up tracks">
        {CATEGORIES.map((cat) => {
          const meta = CATEGORY_META[cat];
          const bundle = bundleFor(cat);
          return (
            <button
              role="tab"
              type="button"
              class={`pu-tab ${cat === 'identity' ? 'is-active' : ''}`}
              data-tab={cat}
              aria-selected={cat === 'identity' ? 'true' : 'false'}
              aria-controls={`panel-${cat}`}
              style={`--accent: ${meta.accent}`}
            >
              <span class="pu-tab-eyebrow">⚡ Track 0{meta.index}</span>
              <span class="pu-tab-name">{bundle.name}</span>
            </button>
          );
        })}
        <button
          role="tab"
          type="button"
          class="pu-tab pu-tab--stack"
          data-tab="stack"
          aria-selected="false"
          aria-controls="panel-stack"
        >
          <span class="pu-tab-eyebrow">🏆 The Stack</span>
          <span class="pu-tab-name">90-Day Complete</span>
        </button>
      </nav>

      <!-- Track panels -->
      {CATEGORIES.map((cat) => {
        const meta = CATEGORY_META[cat];
        const bundle = bundleFor(cat);
        const items = byCategory(cat);
        return (
          <article
            id={`panel-${cat}`}
            class={`pu-panel ${cat === 'identity' ? 'is-active' : ''}`}
            data-panel={cat}
            role="tabpanel"
            style={`--accent: ${meta.accent}`}
          >
            <header class="pu-panel-banner">
              <span class="pu-panel-tag">⚡ Track 0{meta.index} · {meta.label}</span>
              <h2 class="pu-panel-title">{bundle.name}</h2>
              <p class="pu-panel-blurb">{meta.blurb}</p>
            </header>

            <ul class="pu-list">
              {items.map((pu) => (
                <li
                  class="pu-row"
                  data-row={pu.id}
                  data-track={cat}
                  data-price={pu.price}
                >
                  <header class="pu-row-head" data-row-toggle>
                    <div class="pu-row-left">
                      <span class="pu-row-num">{pu.id}</span>
                      <div class="pu-row-meta">
                        <span class="pu-row-name">{pu.name}</span>
                        <span class="pu-row-prereq">
                          {pu.prereq && pu.prereq.length > 0 ? `Requires: ${pu.prereq.join(' + ')}` : 'No prerequisites'}
                        </span>
                      </div>
                    </div>
                    <div class="pu-row-right">
                      <span class="pu-row-price">{pu.price}</span>
                      <span class="pu-row-toggle" aria-hidden="true">+</span>
                    </div>
                  </header>

                  <div class="pu-row-detail">
                    <div class="pu-row-detail-grid">
                      <div class="pu-row-block pu-row-block--full">
                        <span class="pu-row-block-label">What it fixes</span>
                        <p>{pu.fix}</p>
                      </div>
                      <div class="pu-row-block">
                        <span class="pu-row-block-label">Not for you if</span>
                        <p>{pu.notFor}</p>
                      </div>
                      <div class="pu-row-block">
                        <span class="pu-row-block-label">Best moment to buy</span>
                        <p>{pu.bestMoment}</p>
                      </div>
                    </div>

                    {pu.tiers && (
                      <ul class="pu-tier-list">
                        {pu.tiers.map((t) => (
                          <li class="pu-tier">
                            <header><strong>{t.name}</strong><span>{t.timeline}</span></header>
                            <p>{t.description}</p>
                            <span class="pu-tier-price">{t.price}</span>
                          </li>
                        ))}
                      </ul>
                    )}

                    <footer class="pu-row-actions">
                      <button type="button" class="pu-row-select" data-select={pu.id}>
                        <span class="pu-row-select-add">Add to my build</span>
                        <span class="pu-row-select-on">✓ Selected</span>
                      </button>
                    </footer>
                  </div>
                </li>
              ))}
            </ul>

            <article class="pu-bundle-card" data-bundle={cat}>
              <header>
                <span class="pu-bundle-tag">📦 The Bundle</span>
                <h3>{bundle.name}</h3>
                <p>{bundle.tagline}</p>
              </header>

              <div class="pu-bundle-cols">
                <div>
                  <h4>What's included</h4>
                  <ol>
                    {bundle.includes.map((item) => <li>{item}</li>)}
                  </ol>
                </div>
                <div>
                  <h4>The bundle difference</h4>
                  <ul>
                    {bundle.differences.map((d) => <li>{d}</li>)}
                  </ul>
                </div>
              </div>

              <p class="pu-bundle-deposit">
                💎 Bundles require a <strong>25% deposit ({(() => {
                  const n = parseInt(bundle.price.replace(/[^\d]/g, ''), 10);
                  return `$${Math.round(n * 0.25).toLocaleString()}`;
                })()})</strong> to hold your spot. After deposit, we schedule a fit call before the engagement starts.
              </p>

              <footer>
                <div class="pu-bundle-price-block">
                  <span class="pu-bundle-price-label">Investment</span>
                  <span class="pu-bundle-price">{bundle.price}</span>
                  <span class="pu-bundle-individual">Individual total {bundle.individualTotal}</span>
                </div>
                <button type="button" class="pu-bundle-cta" data-bundle-toggle={cat}>
                  <span class="pu-bundle-cta-add">Take the whole box →</span>
                  <span class="pu-bundle-cta-on">✓ Bundle selected — clear to build à la carte</span>
                </button>
              </footer>
            </article>
          </article>
        );
      })}

      <!-- 90-Day Stack panel -->
      <article id="panel-stack" class="pu-panel pu-panel--stack" data-panel="stack" role="tabpanel">
        <div class="pu-stack-card">
          <span class="pu-stack-tag">🏆 The 90-Day Complete Stack</span>
          <h2 class="pu-stack-headline">All three bundles. 90 days. Complete business.</h2>
          <p class="pu-stack-lede">Identity. Sales. Presence. In that order. Run them sequentially and you build a complete business in three months.</p>

          <ol class="pu-stack-phases" aria-label="The 90-day timeline">
            <li class="pu-stack-phase">
              <span class="pu-stack-phase-num">01</span>
              <span class="pu-stack-phase-window">Days 1 – 30</span>
              <h4 class="pu-stack-phase-name">Brand in a Box</h4>
              <p class="pu-stack-phase-desc">Identity built.</p>
              <span class="pu-stack-phase-clock">Clock starts at onboarding.</span>
            </li>
            <li class="pu-stack-phase">
              <span class="pu-stack-phase-num">02</span>
              <span class="pu-stack-phase-window">Days 31 – 60</span>
              <h4 class="pu-stack-phase-name">Sales in a Box</h4>
              <p class="pu-stack-phase-desc">Revenue system installed.</p>
              <span class="pu-stack-phase-clock">Clock starts at first advertising execution or first booking attempt.</span>
            </li>
            <li class="pu-stack-phase">
              <span class="pu-stack-phase-num">03</span>
              <span class="pu-stack-phase-window">Days 61 – 90</span>
              <h4 class="pu-stack-phase-name">Presence in a Box</h4>
              <p class="pu-stack-phase-desc">Market presence deployed.</p>
              <span class="pu-stack-phase-clock">Clock starts at first post going live.</span>
            </li>
          </ol>

          <div class="pu-stack-summary">
            <ul class="pu-stack-breakdown" aria-label="Cost breakdown">
              <li><span class="pu-stack-breakdown-label">Brand</span><span class="pu-stack-breakdown-num">$6,500</span></li>
              <li><span class="pu-stack-breakdown-label">Sales</span><span class="pu-stack-breakdown-num">$16,500</span></li>
              <li><span class="pu-stack-breakdown-label">Presence</span><span class="pu-stack-breakdown-num">$20,000</span></li>
            </ul>

            <div class="pu-stack-summary-foot">
              <div class="pu-stack-total">
                <span class="pu-stack-total-label">Total · 90 days</span>
                <span class="pu-stack-total-num">{COMPLETE_STACK_PRICE}</span>
              </div>
              <button type="button" class="pu-stack-cta" data-stack-toggle>
                <span class="pu-stack-cta-add">Reserve The Complete Stack →</span>
                <span class="pu-stack-cta-on">✓ Stack selected, clear to build à la carte</span>
              </button>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- ── Floating cart bar (collapsed) ───────────────────── -->
  <button
    type="button"
    class="pu-cart-bar"
    data-cart-bar
    aria-label="Open your build"
    aria-haspopup="dialog"
    hidden
  >
    <span class="pu-cart-bar-icon" aria-hidden="true">⚡</span>
    <span class="pu-cart-bar-meta">
      <span class="pu-cart-bar-count" data-bar-count>0 items</span>
      <span class="pu-cart-bar-total" data-bar-total>$0</span>
    </span>
    <span class="pu-cart-bar-cta" aria-hidden="true">
      <span class="pu-cart-bar-cta-text">Review</span>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </span>
  </button>

  <!-- ── Cart dialog (expanded) ──────────────────────────── -->
  <dialog class="pu-cart-dialog" data-cart-dialog aria-labelledby="cart-dialog-title">
    <div class="pu-cart-dialog-inner">
      <header class="pu-cart-dialog-head">
        <div>
          <span class="pu-cart-dialog-eyebrow">Your build</span>
          <span class="pu-cart-dialog-count" data-dialog-count>0 items</span>
        </div>
        <h2 id="cart-dialog-title" class="visually-hidden">Your build</h2>
        <button type="button" class="pu-cart-dialog-close" data-cart-close aria-label="Close">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
          </svg>
        </button>
      </header>

      <ul class="pu-tray-list" data-tray-list></ul>

      <div class="pu-cart-dialog-foot">
        <div class="pu-tray-total">
          <span>Total</span>
          <span data-tray-total>$0</span>
        </div>
        <div class="pu-tray-deposit" data-tray-deposit hidden>
          <span>25% deposit due today</span>
          <span data-tray-deposit-num>$0</span>
        </div>
        <a class="pu-tray-checkout" data-tray-checkout href="/contact">Proceed to Checkout →</a>
        <button type="button" class="pu-tray-clear" data-tray-clear>Clear build</button>
      </div>
    </div>
  </dialog>

  <PlayerXRaySection />
</Base>

<script>
  type Track = 'identity' | 'systems' | 'presence';

  // Mirror data from src/data/powerUps.ts so the tray can total without a fetch.
  const PRICE: Record<string, number> = {
    '1.1': 597, '1.2': 597, '1.3': 597, '1.4': 597, '1.5': 597, '1.6': 597, '1.7': 1597,
    '2.1': 597, '2.2': 597, '2.3': 597, '2.4': 2000, '2.5': 3000, '2.6': 1000, '2.7': 1500, '2.8': 1000, '2.9': 1500,
    '3.1': 1000, '3.2': 2000, '3.3': 2000, '3.4': 2000, '3.5': 4000, '3.6': 0,
  };
  const BUNDLE_PRICE: Record<Track, number> = { identity: 6500, systems: 16500, presence: 20000 };
  const STACK_PRICE = 43000;

  const NAMES: Record<string, string> = {};
  document.querySelectorAll<HTMLElement>('[data-row]').forEach((row) => {
    const id = row.dataset.row!;
    const name = row.querySelector<HTMLElement>('.pu-row-name')!.textContent!.trim();
    NAMES[id] = name;
  });

  const RECOMMENDATION: Record<Track, { title: string; blurb: string }> = {
    identity: {
      title: 'Start with Identity.',
      blurb: "Lock who you are, what you stand for, and how you sound. Everything else is built on this. Brand in a Box is your fastest path to a real foundation.",
    },
    systems: {
      title: 'Start with Systems.',
      blurb: 'Your sales engine is the bottleneck. Sales in a Box installs the infrastructure: lead generation, scripts, booking, CRM, and follow-up. Built so it runs without you in the chair.',
    },
    presence: {
      title: 'Start with Presence.',
      blurb: 'Your market needs to find you and recognize you. Presence in a Box stands up your platform game across Facebook, Instagram, LinkedIn, TikTok, and YouTube — with content in hand for 30 days.',
    },
  };

  // ── State ─────────────────────────────────────────────────
  type State = {
    track: Track | 'stack';
    selected: Set<string>;        // power-up ids
    bundles: Set<Track>;          // track bundles
    stack: boolean;               // 90-day complete stack
    expanded: Set<string>;        // expanded card ids
    quiz: { step: number; answers: Track[] };
  };
  const state: State = {
    track: 'identity',
    selected: new Set(),
    bundles: new Set(),
    stack: false,
    expanded: new Set(),
    quiz: { step: 0, answers: [] },
  };

  // ── Tabs ──────────────────────────────────────────────────
  const tabs = document.querySelectorAll<HTMLButtonElement>('.pu-tab');
  const panels = document.querySelectorAll<HTMLElement>('[data-panel]');

  function setTrack(track: Track | 'stack') {
    state.track = track;
    tabs.forEach((t) => {
      const on = t.dataset.tab === track;
      t.classList.toggle('is-active', on);
      t.setAttribute('aria-selected', String(on));
    });
    panels.forEach((p) => p.classList.toggle('is-active', p.dataset.panel === track));
  }

  tabs.forEach((t) => {
    t.addEventListener('click', () => {
      const tab = t.dataset.tab as Track | 'stack';
      setTrack(tab);
    });
  });

  // ── Quiz ──────────────────────────────────────────────────
  const stage = document.querySelector<HTMLElement>('[data-quiz]')!;
  const steps = stage.querySelectorAll<HTMLElement>('.pu-quiz-step');

  function renderStep() {
    steps.forEach((s) => s.classList.remove('is-active'));
    if (state.quiz.step < steps.length - 1) {
      steps[state.quiz.step].classList.add('is-active');
    } else {
      const winner = pickWinner(state.quiz.answers);
      const r = RECOMMENDATION[winner];
      stage.querySelector<HTMLElement>('[data-quiz-result-title]')!.textContent = r.title;
      stage.querySelector<HTMLElement>('[data-quiz-result-blurb]')!.textContent = r.blurb;
      const goBtn = stage.querySelector<HTMLButtonElement>('[data-quiz-go]')!;
      goBtn.dataset.target = winner;
      stage.querySelector('.pu-quiz-result')!.classList.add('is-active');
    }
  }

  function pickWinner(answers: Track[]): Track {
    const tally: Record<Track, number> = { identity: 0, systems: 0, presence: 0 };
    answers.forEach((a) => { tally[a]++; });
    const order: Track[] = ['identity', 'systems', 'presence'];
    let winner: Track = order[0];
    let max = -1;
    order.forEach((t) => { if (tally[t] > max) { max = tally[t]; winner = t; } });
    return winner;
  }

  stage.querySelectorAll<HTMLButtonElement>('[data-quiz-pick]').forEach((b) => {
    b.addEventListener('click', () => {
      state.quiz.answers.push(b.dataset.quizPick as Track);
      state.quiz.step++;
      renderStep();
    });
  });

  stage.querySelector<HTMLButtonElement>('[data-quiz-restart]')!.addEventListener('click', () => {
    state.quiz = { step: 0, answers: [] };
    renderStep();
  });

  stage.querySelector<HTMLButtonElement>('[data-quiz-go]')!.addEventListener('click', (e) => {
    const target = (e.currentTarget as HTMLButtonElement).dataset.target as Track;
    setTrack(target);
    document.getElementById('tracks')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  // ── Card expand/select ────────────────────────────────────
  document.querySelectorAll<HTMLElement>('[data-row]').forEach((row) => {
    const id = row.dataset.row!;
    const head = row.querySelector<HTMLElement>('[data-row-toggle]')!;
    const selectBtn = row.querySelector<HTMLButtonElement>('[data-select]')!;

    head.addEventListener('click', () => {
      if (state.expanded.has(id)) state.expanded.delete(id);
      else state.expanded.add(id);
      row.classList.toggle('is-open', state.expanded.has(id));
      const t = row.querySelector<HTMLElement>('.pu-row-toggle')!;
      t.textContent = state.expanded.has(id) ? '−' : '+';
    });

    selectBtn.addEventListener('click', () => {
      const track = row.dataset.track as Track;
      if (state.bundles.has(track) || state.stack) return; // gated
      if (state.selected.has(id)) state.selected.delete(id);
      else state.selected.add(id);
      row.classList.toggle('is-selected', state.selected.has(id));
      renderTray();
    });
  });

  // ── Bundle toggles ────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('[data-bundle-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const track = btn.dataset.bundleToggle as Track;
      if (state.bundles.has(track)) {
        state.bundles.delete(track);
      } else {
        state.bundles.add(track);
        // Clear individual selections in this track
        document.querySelectorAll<HTMLElement>(`[data-row][data-track="${track}"]`).forEach((r) => {
          state.selected.delete(r.dataset.row!);
          r.classList.remove('is-selected');
        });
        // Stack and bundle are mutually exclusive
        state.stack = false;
      }
      syncBundleUi();
      renderTray();
    });
  });

  document.querySelector<HTMLButtonElement>('[data-stack-toggle]')!.addEventListener('click', () => {
    state.stack = !state.stack;
    if (state.stack) {
      state.bundles.clear();
      state.selected.clear();
      document.querySelectorAll<HTMLElement>('[data-row]').forEach((r) => r.classList.remove('is-selected'));
    }
    syncBundleUi();
    renderTray();
  });

  function syncBundleUi() {
    document.querySelectorAll<HTMLElement>('[data-bundle]').forEach((b) => {
      const track = b.dataset.bundle as Track;
      b.classList.toggle('is-selected', state.bundles.has(track));
    });
    document.querySelector('.pu-stack-card')!.classList.toggle('is-selected', state.stack);
    // Gate individual rows in tracks where bundle / stack is set.
    document.querySelectorAll<HTMLElement>('[data-row]').forEach((r) => {
      const track = r.dataset.track as Track;
      const gated = state.stack || state.bundles.has(track);
      r.classList.toggle('is-gated', gated);
    });
  }

  // ── Tray render ───────────────────────────────────────────
  const cartBar = document.querySelector<HTMLButtonElement>('[data-cart-bar]')!;
  const cartDialog = document.querySelector<HTMLDialogElement>('[data-cart-dialog]')!;
  const cartClose = document.querySelector<HTMLButtonElement>('[data-cart-close]')!;
  const barCount = document.querySelector<HTMLElement>('[data-bar-count]')!;
  const barTotal = document.querySelector<HTMLElement>('[data-bar-total]')!;
  const dialogCount = document.querySelector<HTMLElement>('[data-dialog-count]')!;
  const trayList = document.querySelector<HTMLUListElement>('[data-tray-list]')!;
  const trayTotal = document.querySelector<HTMLElement>('[data-tray-total]')!;
  const trayDeposit = document.querySelector<HTMLElement>('[data-tray-deposit]')!;
  const trayDepositNum = document.querySelector<HTMLElement>('[data-tray-deposit-num]')!;
  const trayCheckout = document.querySelector<HTMLAnchorElement>('[data-tray-checkout]')!;
  const trayClear = document.querySelector<HTMLButtonElement>('[data-tray-clear]')!;

  function fmt(n: number) {
    return '$' + n.toLocaleString();
  }

  function openCart() {
    if (cartDialog.hasAttribute('open')) return;
    cartDialog.showModal();
  }
  function closeCart() {
    if (!cartDialog.hasAttribute('open')) return;
    cartDialog.close();
  }

  cartBar.addEventListener('click', openCart);
  cartClose.addEventListener('click', closeCart);
  // Click backdrop (clicks land on the dialog itself, not its inner content) to close.
  cartDialog.addEventListener('click', (e) => {
    if (e.target === cartDialog) closeCart();
  });

  function renderTray() {
    const items: { id: string; name: string; price: number; remove: () => void }[] = [];

    if (state.stack) {
      items.push({
        id: 'stack',
        name: '90-Day Complete Stack',
        price: STACK_PRICE,
        remove: () => { state.stack = false; syncBundleUi(); renderTray(); },
      });
    }

    state.bundles.forEach((track) => {
      items.push({
        id: `bundle-${track}`,
        name: BUNDLES_NAMES[track] + ' (Full Bundle)',
        price: BUNDLE_PRICE[track],
        remove: () => { state.bundles.delete(track); syncBundleUi(); renderTray(); },
      });
    });

    state.selected.forEach((id) => {
      items.push({
        id,
        name: NAMES[id] || id,
        price: PRICE[id] ?? 0,
        remove: () => {
          state.selected.delete(id);
          document.querySelector(`[data-row="${id}"]`)?.classList.remove('is-selected');
          renderTray();
        },
      });
    });

    const countLabel = items.length === 1 ? '1 item' : `${items.length} items`;
    barCount.textContent = countLabel;
    dialogCount.textContent = countLabel;

    trayList.innerHTML = '';

    if (items.length === 0) {
      cartBar.hidden = true;
      cartBar.classList.remove('is-visible');
      // If the modal is open and the cart just emptied, dismiss it.
      if (cartDialog.hasAttribute('open')) closeCart();
      return;
    }

    cartBar.hidden = false;
    // Defer one frame so the slide-up transition can run from hidden -> visible.
    requestAnimationFrame(() => cartBar.classList.add('is-visible'));

    items.forEach((it) => {
      const li = document.createElement('li');
      li.className = 'pu-tray-item';
      li.innerHTML = `
        <div class="pu-tray-item-meta">
          <span class="pu-tray-item-name"></span>
          <span class="pu-tray-item-price"></span>
        </div>
        <button type="button" class="pu-tray-item-remove" aria-label="Remove">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
          </svg>
        </button>
      `;
      li.querySelector<HTMLElement>('.pu-tray-item-name')!.textContent = it.name;
      li.querySelector<HTMLElement>('.pu-tray-item-price')!.textContent = fmt(it.price);
      li.querySelector<HTMLButtonElement>('.pu-tray-item-remove')!.addEventListener('click', it.remove);
      trayList.appendChild(li);
    });

    const total = items.reduce((sum, it) => sum + it.price, 0);
    trayTotal.textContent = fmt(total);
    barTotal.textContent = fmt(total);

    const hasBundle = state.stack || state.bundles.size > 0;
    if (hasBundle) {
      trayDeposit.hidden = false;
      trayDepositNum.textContent = fmt(Math.round(total * 0.25));
      trayCheckout.textContent = `Reserve my spot · ${fmt(Math.round(total * 0.25))} deposit →`;
    } else {
      trayDeposit.hidden = true;
      trayCheckout.textContent = `Proceed to Checkout · ${fmt(total)} →`;
    }

    // Encode the selection into the contact link query string.
    const params = new URLSearchParams();
    if (state.stack) params.set('cart', 'stack');
    if (state.bundles.size) params.set('bundles', Array.from(state.bundles).join(','));
    if (state.selected.size) params.set('powerups', Array.from(state.selected).join(','));
    trayCheckout.href = `/contact?${params.toString()}`;
  }

  trayClear.addEventListener('click', () => {
    state.selected.clear();
    state.bundles.clear();
    state.stack = false;
    document.querySelectorAll<HTMLElement>('[data-row]').forEach((r) => r.classList.remove('is-selected'));
    syncBundleUi();
    renderTray();
  });

  const BUNDLES_NAMES: Record<Track, string> = {
    identity: 'Brand in a Box',
    systems: 'Sales in a Box',
    presence: 'Presence in a Box',
  };

  // Initial render
  syncBundleUi();
  renderTray();
</script>

