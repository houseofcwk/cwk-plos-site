---
import CaseStudy from '../../layouts/CaseStudy.astro';
import PortableText from '../../components/PortableText.astro';
import { sanity, urlFor } from '../../lib/sanity';
import { CASE_SLUGS_QUERY, CASE_BY_SLUG_QUERY } from '../../lib/queries';

// Hardcoded slugs still served by their explicit page files; exclude them
// from the dynamic route so Astro doesn't see a route collision and so the
// hardcoded fallbacks keep winning until Sanity is fully seeded.
const EXCLUDED_SLUGS = new Set<string>([
  'dawa',
  'lifes-tapestry',
  'pay-the-creators',
  'raasin-in-the-sun',
  'rob-dial',
  'spraycation',
  'stephy-lee',
  'the-lab-miami',
]);

export async function getStaticPaths() {
  let slugs: string[] = [];
  try {
    slugs = (await sanity.fetch(CASE_SLUGS_QUERY)) ?? [];
  } catch {
    slugs = [];
  }
  return slugs
    .filter((slug) => slug && !EXCLUDED_SLUGS.has(slug))
    .map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const cs = await sanity.fetch(CASE_BY_SLUG_QUERY, { slug });
if (!cs) {
  throw new Error(`Case study not found: ${slug}`);
}
---

<CaseStudy
  title={cs.seo?.title ?? `${cs.client} | CWK. Experience`}
  description={cs.seo?.description ?? cs.cardDescription ?? ''}
  category={cs.category}
  client={cs.client}
  headline={cs.headline ?? cs.client}
  duration={cs.duration}
  result={cs.result}
  resultLabel={cs.resultLabel}
>
  {cs.body && (
    <div class="cs-body-pt"><PortableText value={cs.body} /></div>
  )}

  {cs.testimonial?.quote && (
    <blockquote class="cs-quote">
      <p>"{cs.testimonial.quote}"</p>
      <footer>– {cs.testimonial.author}{cs.testimonial.role ? `, ${cs.testimonial.role}` : ''}</footer>
    </blockquote>
  )}

  {cs.images?.length > 0 && (
    <div class="cs-gallery">
      {cs.images.map((img: any) => (
        <img src={urlFor(img).width(1400).auto('format').url()} alt={img.alt ?? ''} loading="lazy" />
      ))}
    </div>
  )}
</CaseStudy>

<style>
  .cs-body-pt :global(h2) { font-size: 22px; font-weight: 700; margin: 32px 0 12px; color: var(--text); }
  .cs-body-pt :global(h3) { font-size: 18px; font-weight: 700; margin: 24px 0 10px; color: var(--text); }
  .cs-body-pt :global(p)  { margin: 0 0 14px; line-height: 1.7; color: var(--muted); font-size: 15px; }
  .cs-body-pt :global(a)  { color: var(--cyan); }
  .cs-body-pt :global(img){ width: 100%; height: auto; border-radius: 12px; margin: 24px 0; }
  .cs-quote { margin: 32px 0; padding: 24px 28px; border-left: 3px solid var(--cyan); background: rgba(0,229,255,0.04); border-radius: 8px; }
  .cs-quote p { font-size: 17px; line-height: 1.55; color: var(--text); margin: 0 0 10px; font-style: italic; }
  .cs-quote footer { font-size: 13px; color: var(--dim); }
  .cs-gallery { display: grid; gap: 16px; margin: 32px 0; }
</style>
