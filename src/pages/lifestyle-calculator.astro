    if (peopleEl) {
      peopleEl.innerHTML = `
        <div class="lc-res-card">
          <span class="lc-res-badge">PEOPLE YOU NEED, AT YOUR SPEED</span>
          <div class="lc-people-list">
            ${ppl.list.map((p) => `
              <div class="lc-people-item">
                <div>
                  <div class="lc-people-who">${escapeHtml(p.who)}</div>
                  <div class="lc-people-note">${escapeHtml(p.note)}</div>
                </div>
                ${p.cost ? `<div class="lc-people-cost">${escapeHtml(p.cost)}</div>` : `<div class="lc-people-cost lc-people-cost-free">Free</div>`}
              </div>`).join('')}
          </div>
          <div class="lc-people-total-row">
            <div class="lc-people-total">Total people investment: <span>${escapeHtml(ppl.total)}</span></div>
            <div class="lc-people-truth">${escapeHtml(ppl.truth)}</div>
