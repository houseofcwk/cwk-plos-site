    const toolsEl = document.getElementById('lcResTools');
    if (toolsEl) {
      toolsEl.innerHTML = `
        <div class="lc-breakdown-card">
          <span class="lc-breakdown-title">RECOMMENDED STACK FOR YOUR SPEED</span>
          <div class="lc-tool-pills">${toolPills}</div>
          <div class="lc-tool-cost">Estimated tool cost: <span>${SPEED_TOOL_COST[spd]}</span></div>
