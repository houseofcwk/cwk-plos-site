  function getTimeline(archId: ArchetypeKey, targetMonths: number): { color: string; when: string; what: string }[] {
    const stages: Record<ArchetypeKey, [string, string, string][]> = {
      explorer: [
        ['#00E396', 'Week 1 to 2', 'First real conversation happens'],
        ['#00E5FF', 'Month 1 to 3', 'First paying client'],
        ['#7B61FF', 'Month 3 to 6', 'First consistent month'],
        ['#FB3079', `Month ${targetMonths}`, 'Target revenue hit'],
      ],
      committer: [
        ['#00E396', 'Week 1 to 4', 'Offer goes live, imperfect is fine'],
        ['#00E5FF', 'Month 1 to 2', 'First closed sale'],
        ['#7B61FF', 'Month 3 to 5', 'Repeatability proven'],
        ['#FB3079', `Month ${targetMonths}`, 'Target revenue hit'],
      ],
      builder: [
        ['#00E396', 'Week 1 to 4', 'Revenue source audit complete'],
        ['#00E5FF', 'Month 1 to 3', 'First system built'],
        ['#7B61FF', 'Month 3 to 6', 'First real delegation'],
        ['#FB3079', `Month ${targetMonths}`, 'Predictable revenue achieved'],
