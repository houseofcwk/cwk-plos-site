        minesEl.innerHTML = '';
        warnEl.innerHTML = '';
      } else {
        const items = state.mines.map((mk) => {
          const m = MINES.find((x) => x.key === mk);
          if (!m) return '';
          return `
            <div class="lc-mine-result-item">
              <div class="lc-mine-result-name">${m.label}</div>
              <div class="lc-mine-result-stat">${m.stat}</div>
