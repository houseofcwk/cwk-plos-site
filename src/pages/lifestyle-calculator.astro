---
import Base from '../layouts/Base.astro';
import {
  CATEGORIES,
  ARCHETYPES,
  SPEEDS,
  MINES,
} from '../data/lifestyleCalculator';

const pageTitle = 'Lifestyle Calculator | CWK. Experience';
const pageDescription =
  'Turn your lifestyle aspirations into a concrete income target and a plan that fits the pace you can actually keep. Six squares. Real numbers. No fluff.';
---

<Base title={pageTitle} description={pageDescription}>
  <section class="lc-page">
    <div class="lc-wrap">

      <!-- Board path indicator -->
      <div class="lc-board-wrap">
        <div class="lc-board" id="lcBoard"></div>
      </div>

      <!-- ── SECTION 01: YOUR EDGE ─────────────────────────── -->
      <div id="lc-step-0" class="lc-step is-active">
        <span class="lc-eyebrow"><span class="lc-eyebrow-dot"></span>SECTION 01 / YOUR CATEGORY</span>
        <h1 class="lc-h1">What does your<br><span class="lc-grad">lifestyle really cost?</span></h1>
        <p class="lc-sub">Pick the category that matches what you want to monetize.</p>

        <div class="lc-cat-grid">
          {CATEGORIES.map((cat) => (
            <button type="button" class={`lc-cat-tile lc-${cat.key}`} data-cat={cat.key}>
              <span class="lc-cat-icon" aria-hidden="true">
                {cat.icon === 'mind' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3a4 4 0 0 0-4 4v1a3 3 0 0 0-2 2.83v.34A3 3 0 0 0 5 14v.5A3.5 3.5 0 0 0 8.5 18H9v3h2V3Z"/><path d="M15 3a4 4 0 0 1 4 4v1a3 3 0 0 1 2 2.83v.34A3 3 0 0 1 19 14v.5A3.5 3.5 0 0 1 15.5 18H15v3h-2V3Z"/></svg>
                )}
                {cat.icon === 'body' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="m6.5 6.5 11 11"/><path d="m21 21-1-1"/><path d="m3 3 1 1"/><path d="m18 22 4-4"/><path d="m2 6 4-4"/><path d="m3 10 7-7"/><path d="m14 21 7-7"/></svg>
                )}
                {cat.icon === 'soul' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.29 1.51 4.04 3 5.5l7 7Z"/></svg>
                )}
                {cat.icon === 'pocket' && (
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="6" width="18" height="13" rx="2"/><path d="M3 10h18"/><path d="M7 15h2"/></svg>
                )}
              </span>
              <span class="lc-cat-label">{cat.label}</span>
              <span class="lc-cat-desc">{cat.desc}</span>
              <span class="lc-cat-check" aria-hidden="true">✓</span>
            </button>
          ))}
        </div>

        <div class="lc-sub-wrap" id="lcSubWrap" hidden>
          <div class="lc-sub-label">WHAT SPECIFICALLY?</div>
          <div class="lc-sub-grid" id="lcSubGrid"></div>
        </div>

        <div class="lc-nav-row" style="margin-top:28px;">
          <button type="button" class="lc-btn-next" data-next="0">Continue →</button>
        </div>
      </div>

      <!-- ── SECTION 02: YOUR STAGE ────────────────────────── -->
      <div id="lc-step-1" class="lc-step">
        <span class="lc-eyebrow"><span class="lc-eyebrow-dot"></span>SECTION 02 / YOUR STAGE</span>
        <h1 class="lc-h1">Where are you<br><span class="lc-grad">right now?</span></h1>
        <p class="lc-sub">Not where you want to be. Where you actually are today. Read each one and pick the card that sounds like your internal monologue this week.</p>

        <div class="lc-arch-list">
          {ARCHETYPES.map((a) => (
            <button type="button" class="lc-arch-card" data-arch={a.key}>
              <span class="lc-arch-check" aria-hidden="true">✓</span>
              <div class="lc-arch-header">
                <div class="lc-arch-name-wrap">
                  <span class="lc-arch-tag">{a.tag}</span>
                  <div class="lc-arch-name">{a.name}</div>
                </div>
                <div class="lc-arch-dots" aria-hidden="true">
                  {[1, 2, 3, 4, 5].map((d) => (
                    <span class={`lc-arch-dot ${d === a.stage ? 'is-active' : ''}`}></span>
                  ))}
                </div>
              </div>
              <div class="lc-arch-feeling">{a.feeling}</div>
              <div class="lc-arch-cost-row">
                <span class="lc-arch-cost-tag">THE COST</span>
                <span class="lc-arch-cost-val">{a.cost}</span>
              </div>
            </button>
          ))}
        </div>

        <div class="lc-nav-row">
          <button type="button" class="lc-btn-back" data-back="1">←</button>
          <button type="button" class="lc-btn-next" data-next="1">Continue →</button>
        </div>
      </div>

      <!-- ── SECTION 03: THE PRIZE ─────────────────────────── -->
      <div id="lc-step-2" class="lc-step">
        <span class="lc-eyebrow"><span class="lc-eyebrow-dot"></span>SECTION 03 / THE PRIZE</span>
        <h1 class="lc-h1">Where do you<br><span class="lc-grad">want to be?</span></h1>
        <p class="lc-sub">Let's calculate what it would take to bring this to life.</p>
        <p class="lc-section-tag">The real numbers to get to where you want to be.</p>

        <div class="lc-field-grid">
          <div class="lc-field-group">
            <label class="lc-field-label" for="lc-monthly-goal">How much do you want to make a month?</label>
            <div class="lc-field-prefix">
              <span class="lc-field-prefix-mark">$</span>
              <input type="number" id="lc-monthly-goal" placeholder="10,000" min="1" inputmode="numeric" />
            </div>
          </div>
          <div class="lc-field-group">
            <label class="lc-field-label" for="lc-offer-price">How much is your service or product?</label>
            <div class="lc-field-prefix">
              <span class="lc-field-prefix-mark">$</span>
              <input type="number" id="lc-offer-price" placeholder="2,500" min="1" inputmode="numeric" />
            </div>
          </div>
        </div>

        <div class="lc-field-grid" style="margin-top:2px;">
          <div class="lc-field-group">
            <label class="lc-field-label" for="lc-hours-week">Hours a week you can invest</label>
            <input type="number" id="lc-hours-week" placeholder="15" min="1" max="168" inputmode="numeric" />
          </div>
          <div class="lc-field-group">
            <label class="lc-field-label" for="lc-time-months">Months to hit your goal</label>
            <input type="number" id="lc-time-months" placeholder="12" min="1" inputmode="numeric" />
          </div>
        </div>

        <div class="lc-nav-row">
          <button type="button" class="lc-btn-back" data-back="2">←</button>
          <button type="button" class="lc-btn-next" data-next="2">Continue →</button>
        </div>
      </div>

      <!-- ── SECTION 04: GAME SPEED ────────────────────────── -->
      <div id="lc-step-3" class="lc-step">
        <span class="lc-eyebrow"><span class="lc-eyebrow-dot"></span>SECTION 04 / GAME SPEED</span>
        <h1 class="lc-h1">How fast are<br><span class="lc-grad">you willing to move?</span></h1>
        <p class="lc-sub">Every speed is real. Every speed has a real cost. Pick the one you will actually show up at, not the one that sounds like the right answer.</p>

        <div class="lc-speed-grid">
          {SPEEDS.map((s) => (
            <button type="button" class={`lc-speed-card lc-speed-${s.key}`} data-speed={s.key}>
              <span class="lc-speed-symbol" aria-hidden="true">
                {s.key === 'turtle' && (
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 16a5 5 0 0 0 5-5 5 5 0 0 0-10 0 5 5 0 0 0 5 5z"/><path d="M5 11a7 7 0 0 1 14 0"/><path d="M3 16h2"/><path d="M19 16h2"/><path d="M5 19l1-2"/><path d="M19 19l-1-2"/><path d="M9 19l-1 2"/><path d="M15 19l1 2"/></svg>
                )}
                {s.key === 'car' && (
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 16H9m10 0h3v-3.15a1 1 0 0 0-.84-.99L16 11l-2.7-3.6a1 1 0 0 0-.8-.4H5.24a2 2 0 0 0-1.8 1.1l-.8 1.63A6 6 0 0 0 2 12.42V16h2"/><circle cx="6.5" cy="16.5" r="2.5"/><circle cx="16.5" cy="16.5" r="2.5"/></svg>
                )}
                {s.key === 'rocket' && (
                  <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>
                )}
              </span>
              <span class="lc-speed-label">{s.label}</span>
              <span class="lc-speed-time">{s.time}</span>
              <span class="lc-speed-desc">{s.desc}</span>
              <span class="lc-speed-check" aria-hidden="true">✓</span>
            </button>
          ))}
        </div>

        <div class="lc-nav-row">
          <button type="button" class="lc-btn-back" data-back="3">←</button>
          <button type="button" class="lc-btn-next" data-next="3">Continue →</button>
        </div>
      </div>

      <!-- ── SECTION 05: THE TWO BRIDGES ───────────────────── -->
      <div id="lc-step-4" class="lc-step">
        <span class="lc-eyebrow"><span class="lc-eyebrow-dot"></span>SECTION 05 / THE TWO BRIDGES</span>
        <h1 class="lc-h1">Here's what<br><span class="lc-grad">the numbers say.</span></h1>
        <p class="lc-sub">Two bridges sit between your idea and your income. Bridge one: strangers to interested leads. Bridge two: leads to buyers. Defaults below assume 1% and 20%, honest baselines for someone with no existing audience. Adjust if you have real data.</p>

        <div class="lc-funnel-top" id="lcFunnelTop"></div>
        <div class="lc-funnel-arrows" id="lcFunnelArrows"></div>
        <div class="lc-funnel-bottom" id="lcFunnelBottom"></div>

        <hr class="lc-divider" />

        <div class="lc-adjust-block">
          <div class="lc-adjust-title">Adjust for your real conversion rates</div>
          <div class="lc-adjust-grid">
            <div class="lc-adjust-field">
              <label for="lc-s2l-rate">Stranger → Lead (%)</label>
              <input type="number" id="lc-s2l-rate" placeholder="1" min="0.1" max="100" step="0.1" />
            </div>
            <div class="lc-adjust-field">
              <label for="lc-l2s-rate">Lead → Sale (%)</label>
              <input type="number" id="lc-l2s-rate" placeholder="20" min="0.1" max="100" step="0.1" />
            </div>
          </div>
        </div>

        <div class="lc-nav-row">
          <button type="button" class="lc-btn-back" data-back="4">←</button>
          <button type="button" class="lc-btn-next" data-next="4">Continue →</button>
        </div>
      </div>

      <!-- ── SECTION 06: MIND MINES ────────────────────────── -->
      <div id="lc-step-5" class="lc-step">
        <span class="lc-eyebrow"><span class="lc-eyebrow-dot"></span>SECTION 06 / MIND MINES</span>
        <h1 class="lc-h1">What's<br><span class="lc-grad">in your way?</span></h1>
        <p class="lc-sub">These are not character flaws. They are the actual cost of playing. Select every one that is true right now. The more honest you are here, the more useful your map becomes.</p>

        <div class="lc-mine-list">
          {MINES.map((m) => (
            <div class="lc-mine-item" data-mine={m.key}>
              <div class="lc-mine-stat-bar">{m.stat}</div>
              <div class="lc-mine-body">
                <div class="lc-mine-check" aria-hidden="true">✓</div>
                <div class="lc-mine-content">
                  <div class="lc-mine-label">{m.label}</div>
                  <div class="lc-mine-desc">{m.desc}</div>
                  <div class="lc-mine-fix">{m.fix}</div>
                </div>
              </div>
            </div>
          ))}
          <div class="lc-mine-item" data-mine="none">
            <div class="lc-mine-body">
              <div class="lc-mine-check" aria-hidden="true">✓</div>
              <div class="lc-mine-content">
                <div class="lc-mine-label">None of these. I am clear.</div>
                <div class="lc-mine-desc">You have done the inner work, or none of these are active blocks right now.</div>
              </div>
            </div>
          </div>
        </div>

        <div class="lc-nav-row">
          <button type="button" class="lc-btn-back" data-back="5">←</button>
          <button type="button" class="lc-btn-next" data-next="5">Build my lifestyle map →</button>
        </div>
      </div>

      <!-- ── RESULTS ──────────────────────────────────────── -->
      <div id="lc-step-6" class="lc-step">
        <span class="lc-eyebrow"><span class="lc-eyebrow-dot"></span>YOUR LIFESTYLE MAP</span>
        <h1 class="lc-h1"><span class="lc-grad">Your complete<br>picture.</span></h1>
        <p class="lc-sub">Where you are. Where you want to be. What it actually takes to get there. Everything in one place so you can make a real decision.</p>

        <!-- Identity Header -->
        <div class="lc-player-header">
          <div class="lc-player-badges" id="lcPlayerBadges"></div>
          <div class="lc-player-headline" id="lcPlayerHeadline"></div>
          <div class="lc-player-stats" id="lcPlayerStats"></div>
        </div>

        <!-- Where you are now -->
        <span class="lc-section-label">WHERE YOU ARE RIGHT NOW</span>
        <div id="lcResArchetype"></div>

        <!-- Where you want to be -->
        <span class="lc-section-label">WHERE YOU WANT TO BE</span>
        <div id="lcResDestination"></div>

        <!-- Timeline -->
        <span class="lc-section-label">YOUR TIMELINE</span>
        <div id="lcResTimeline"></div>

        <!-- Tools -->
        <span class="lc-section-label">RECOMMENDED TOOLS</span>
        <div id="lcResTools"></div>

        <!-- Skills -->
        <span class="lc-section-label">SKILLS TO BUILD</span>
        <div id="lcResSkills"></div>

        <!-- People -->
        <span class="lc-section-label">PEOPLE YOU NEED</span>
        <div id="lcResPeople"></div>

        <!-- Stress -->
        <span class="lc-section-label">THE STRESS REALITY</span>
        <div id="lcResStress"></div>

        <!-- Phase roadmap -->
        <span class="lc-section-label">YOUR PHASE ROADMAP</span>
        <div class="lc-phase-grid" id="lcResPhases"></div>

        <!-- Mind mines results -->
        <div id="lcResMines"></div>
        <div id="lcResWarning"></div>

        <!-- Email me my map -->
        <div class="lc-email-card" id="lcEmailCard">
          <span class="lc-email-eyebrow">EMAIL ME MY MAP</span>
          <h3 class="lc-email-title">Want this map in your inbox?</h3>
          <p class="lc-email-sub">We will send you a copy of your full lifestyle map so you can revisit it any time. No spam, ever.</p>
          <form class="lc-email-form" id="lcEmailForm" novalidate>
            <input type="email" id="lc-email-input" placeholder="your@email.com" autocomplete="email" required />
            <button type="submit" class="lc-email-btn" id="lcEmailBtn">Send my map →</button>
          </form>
          <p class="lc-email-msg" id="lcEmailMsg" role="status" aria-live="polite"></p>
        </div>

        <!-- CTA -->
        <div class="lc-cta-section">
          <div class="lc-cta-intro">
            <span class="lc-cta-eyebrow">YOUR NEXT MOVE</span>
            <h2 class="lc-cta-title">You have the map.<br>Now choose your path.</h2>
            <p class="lc-cta-sub">Two options. One moves faster than the other. Neither is wrong. One is just more intentional.</p>
          </div>
          <div class="lc-cta-paths">
            <div class="lc-cta-path lc-cta-path-a">
              <span class="lc-path-label lc-path-a-label">PATH A</span>
              <div class="lc-cta-path-title">Tour CWK.<br>Online HQ</div>
              <p class="lc-cta-path-desc">See the full operating system. Community, frameworks, done-for-you infrastructure, and execution support built for founders who are ready to stop figuring it out alone. No pitch. Just a real look inside.</p>
              <a class="lc-btn-path-a" href="https://cwkexperience.com" target="_blank" rel="noopener">Tour CWK HQ →</a>
            </div>
            <div class="lc-cta-path lc-cta-path-b">
              <span class="lc-path-label lc-path-b-label">PATH B / FOR NEXT TIME</span>
              <div class="lc-cta-path-title">Keep this<br>calculator.</div>
              <p class="lc-cta-path-desc">Bookmark it. Come back the next time an idea needs a reality check before you commit. This map does not expire. Neither does your dream.</p>
              <button type="button" class="lc-btn-path-b" id="lcResetBtn">Run a new idea ↺</button>
            </div>
          </div>
        </div>

        <div class="lc-footer-note">
          Built by <a href="https://cwkexperience.com" target="_blank" rel="noopener">CWK. Experience</a>
          &nbsp;·&nbsp; Build. Learn. Earn. Play.
        </div>
      </div>

    </div>
  </section>
</Base>

<script>
  import {
    CATEGORIES,
    ARCHETYPES,
    SPEEDS,
    MINES,
    TOOLS,
    SKILLS,
    PEOPLE,
    PHASES,
    SPEED_TOOL_COST,
    SPEED_TIME_LABELS,
    type CategoryKey,
    type SpeedKey,
    type ArchetypeKey,
    type MineKey,
    type CalculatorState,
  } from '../data/lifestyleCalculator';

  // ── State ───────────────────────────────────────────────
  const STORAGE_KEY = 'cwk:lifestyle-calculator:v1';
  const SQUARE_LABELS = ['01', '02', '03', '04', '05', '06', '★'];

  const initialState: CalculatorState = {
    ideaCategory: '',
    ideaType: '',
    archetype: '',
    monthlyGoal: 0,
    offerPrice: 0,
    hoursWeek: 0,
    timeMonths: 0,
    speed: '',
    s2l: 1,
    l2s: 20,
    mines: [],
  };

  let state: CalculatorState = { ...initialState };
  let currentStep = 0;

  function loadState(): void {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw) as { state?: CalculatorState; step?: number };
      if (parsed.state) state = { ...initialState, ...parsed.state };
      if (typeof parsed.step === 'number' && parsed.step >= 0 && parsed.step <= 6) {
        currentStep = parsed.step;
      }
    } catch {
      // bad JSON, start fresh
    }
  }

  function saveState(): void {
    try {
      localStorage.setItem(
        STORAGE_KEY,
        JSON.stringify({ state, step: currentStep })
      );
    } catch {
      // localStorage disabled or full
    }
  }

  function clearState(): void {
    try { localStorage.removeItem(STORAGE_KEY); } catch {}
  }

  // ── Board ───────────────────────────────────────────────
  function renderBoard(active: number): void {
    const board = document.getElementById('lcBoard');
    if (!board) return;
    let html = '';
    for (let i = 0; i < SQUARE_LABELS.length; i++) {
      if (i > 0) html += '<div class="lc-board-conn"></div>';
      const isGoal = i === SQUARE_LABELS.length - 1;
      const cls = [
        'lc-board-sq',
        isGoal ? 'is-goal' : '',
        i < active ? 'is-done' : '',
        i === active ? 'is-active' : '',
      ].filter(Boolean).join(' ');
      html += `<div class="${cls}">${SQUARE_LABELS[i]}</div>`;
    }
    board.innerHTML = html;
  }

  // ── Navigation ──────────────────────────────────────────
  function showStep(n: number): void {
    document.querySelectorAll<HTMLElement>('.lc-step').forEach((el) => {
      el.classList.remove('is-active');
    });
    const target = document.getElementById(`lc-step-${n}`);
    if (target) target.classList.add('is-active');
    currentStep = n;
    renderBoard(n);
    saveState();

    if (n === 4) renderFunnel();
    if (n === 6) buildResults();

    const wrap = document.querySelector<HTMLElement>('.lc-page');
    if (wrap) {
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      requestAnimationFrame(() => {
        wrap.scrollIntoView({ behavior: prefersReduced ? 'auto' : 'smooth', block: 'start' });
      });
    }
  }

  function flashEl(id: string): void {
    const el = document.getElementById(id);
    if (!el) return;
    el.classList.add('lc-flash');
    setTimeout(() => el.classList.remove('lc-flash'), 1400);
  }

  // ── Step 0: category + sub-option ───────────────────────
  function selectCat(key: CategoryKey, btn: HTMLElement): void {
    document.querySelectorAll('.lc-cat-tile').forEach((el) => el.classList.remove('is-selected'));
    btn.classList.add('is-selected');
    state.ideaCategory = key;
    state.ideaType = '';
    renderSubOptions(key);
    saveState();
  }

  function renderSubOptions(key: CategoryKey): void {
    const cat = CATEGORIES.find((c) => c.key === key);
    const wrap = document.getElementById('lcSubWrap');
    const grid = document.getElementById('lcSubGrid');
    if (!cat || !wrap || !grid) return;
    grid.innerHTML = cat.subOptions
      .map(
        (o) => `<button type="button" class="lc-sub-opt" data-sub="${o.id}">
          <span class="lc-sub-check">✓</span>
          <div class="lc-sub-opt-label">${o.label}</div>
          <div class="lc-sub-opt-desc">${o.desc}</div>
        </button>`
      )
      .join('');
    wrap.removeAttribute('hidden');

    grid.querySelectorAll<HTMLButtonElement>('.lc-sub-opt').forEach((btn) => {
      btn.addEventListener('click', () => {
        grid.querySelectorAll('.lc-sub-opt').forEach((el) => el.classList.remove('is-selected'));
        btn.classList.add('is-selected');
        state.ideaType = btn.dataset.sub ?? '';
        if (state.ideaType === btn.dataset.sub) {
          // re-mark from saved state
        }
        saveState();
      });
      if (btn.dataset.sub === state.ideaType) btn.classList.add('is-selected');
    });
  }

  // ── Step 1: archetype ──────────────────────────────────
  function wireArchetypes(): void {
    document.querySelectorAll<HTMLButtonElement>('.lc-arch-card').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.lc-arch-card').forEach((el) => el.classList.remove('is-selected'));
        btn.classList.add('is-selected');
        state.archetype = (btn.dataset.arch as ArchetypeKey) ?? '';
        saveState();
      });
    });
  }

  // ── Step 3: speed ──────────────────────────────────────
  function wireSpeeds(): void {
    document.querySelectorAll<HTMLButtonElement>('.lc-speed-card').forEach((btn) => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.lc-speed-card').forEach((el) => el.classList.remove('is-selected'));
        btn.classList.add('is-selected');
        state.speed = (btn.dataset.speed as SpeedKey) ?? '';
        saveState();
      });
    });
  }

  // ── Step 5: mines ──────────────────────────────────────
  function toggleMine(item: HTMLElement, key: string): void {
    if (key === 'none') {
      state.mines = [];
      document.querySelectorAll('.lc-mine-item').forEach((el) => el.classList.remove('is-selected'));
      item.classList.add('is-selected');
      saveState();
      return;
    }
    // Deselect "none"
    const noneItem = document.querySelector('.lc-mine-item[data-mine="none"]');
    if (noneItem) noneItem.classList.remove('is-selected');

    const mineKey = key as MineKey;
    const idx = state.mines.indexOf(mineKey);
    if (idx >= 0) {
      state.mines.splice(idx, 1);
      item.classList.remove('is-selected');
    } else {
      state.mines.push(mineKey);
      item.classList.add('is-selected');
    }
    saveState();
  }

  function wireMines(): void {
    document.querySelectorAll<HTMLElement>('.lc-mine-item').forEach((item) => {
      item.addEventListener('click', () => {
        toggleMine(item, item.dataset.mine ?? '');
      });
    });
  }

  // ── Math ───────────────────────────────────────────────
  function calcNumbers(): {
    totalSales: number; salesPw: number; leadsPw: number; strangersPw: number;
  } {
    const g = state.monthlyGoal, p = state.offerPrice, m = state.timeMonths;
    const s2l = state.s2l, l2s = state.l2s;
    const weeks = Math.max(1, m * 4.33);
    const totalSales = Math.ceil((g * m) / Math.max(1, p));
    const totalLeads = Math.ceil(totalSales / (l2s / 100));
    const totalStrangers = Math.ceil(totalLeads / (s2l / 100));
    return {
      totalSales,
      salesPw: Math.ceil(totalSales / weeks),
      leadsPw: Math.ceil(totalLeads / weeks),
      strangersPw: Math.ceil(totalStrangers / weeks),
    };
  }

  function fmt(n: number): string {
    return new Intl.NumberFormat('en-US').format(Math.round(n));
  }

  function fmtK(n: number): string {
    if (n >= 1000) return (n / 1000).toFixed(n % 1000 === 0 ? 0 : 1) + 'k';
    return fmt(n);
  }

  function renderFunnel(): void {
    const n = calcNumbers();
    const top = document.getElementById('lcFunnelTop');
    const arrows = document.getElementById('lcFunnelArrows');
    const bottom = document.getElementById('lcFunnelBottom');
    if (!top || !arrows || !bottom) return;

    top.innerHTML =
      fCard(fmt(n.strangersPw), 'New people / week') +
      fCard(fmt(n.leadsPw), 'Leads / week') +
      fCard(fmt(n.salesPw), 'Sales / week');
    arrows.innerHTML = '<span>↓</span><span>↓</span><span>↓</span>';
    bottom.innerHTML = `
      <div class="lc-funnel-card lc-funnel-total">
        <div class="lc-funnel-total-num">${fmt(n.totalSales)}</div>
        <div class="lc-funnel-total-meta">
          <div class="lc-funnel-lbl">Total sales over ${state.timeMonths} months</div>
          <p>To reach $${fmtK(state.monthlyGoal)}/mo at $${fmtK(state.offerPrice)} per offer.</p>
        </div>
      </div>`;
  }

  function fCard(num: string, lbl: string): string {
    return `<div class="lc-funnel-card"><div class="lc-funnel-num">${num}</div><div class="lc-funnel-lbl">${lbl}</div></div>`;
  }

  // ── Validation per-step ────────────────────────────────
  function validateStep(step: number): boolean {
    if (step === 0) {
      if (!state.ideaCategory) {
        flashEl('lc-step-0');
        return false;
      }
      if (!state.ideaType) {
        flashEl('lcSubGrid');
        return false;
      }
      return true;
    }
    if (step === 1) {
      if (!state.archetype) {
        flashEl('lc-step-1');
        return false;
      }
      return true;
    }
    if (step === 2) {
      const g = parseFloat((document.getElementById('lc-monthly-goal') as HTMLInputElement).value);
      const p = parseFloat((document.getElementById('lc-offer-price') as HTMLInputElement).value);
      const h = parseFloat((document.getElementById('lc-hours-week') as HTMLInputElement).value);
      const t = parseFloat((document.getElementById('lc-time-months') as HTMLInputElement).value);
      if (!g || !p || !h || !t) {
        flashEl('lc-step-2');
        return false;
      }
      state.monthlyGoal = g;
      state.offerPrice = p;
      state.hoursWeek = h;
      state.timeMonths = t;
      return true;
    }
    if (step === 3) {
      if (!state.speed) {
        flashEl('lc-step-3');
        return false;
      }
      return true;
    }
    if (step === 4) {
      const s2lEl = document.getElementById('lc-s2l-rate') as HTMLInputElement;
      const l2sEl = document.getElementById('lc-l2s-rate') as HTMLInputElement;
      const s2l = parseFloat(s2lEl.value) || 1;
      const l2s = parseFloat(l2sEl.value) || 20;
      state.s2l = s2l;
      state.l2s = l2s;
      return true;
    }
    return true;
  }

  // ── Results ────────────────────────────────────────────
  function getArch(key: ArchetypeKey | ''): typeof ARCHETYPES[number] | null {
    return ARCHETYPES.find((a) => a.key === key) ?? null;
  }

  function getSubLabel(cat: CategoryKey | '', typeId: string): string {
    if (!cat) return '';
    const c = CATEGORIES.find((x) => x.key === cat);
    if (!c) return '';
    return c.subOptions.find((o) => o.id === typeId)?.label ?? '';
  }

  function statCell(val: string, lbl: string): string {
    return `<div class="lc-stat-cell"><div class="lc-stat-val">${val}</div><div class="lc-stat-lbl">${lbl}</div></div>`;
  }

  function escapeHtml(s: string): string {
    return s.replace(/[<>&"']/g, (c) => ({ '<': '&lt;', '>': '&gt;', '&': '&amp;', '"': '&quot;', "'": '&#39;' }[c] as string));
  }

  function buildResults(): void {
    const n = calcNumbers();
    const arch = getArch(state.archetype);
    const cat = state.ideaCategory;
    const spd = state.speed || 'car';

    const catLabels: Record<string, string> = { mind: 'MIND', body: 'BODY', soul: 'SOUL', pocket: 'POCKET' };
