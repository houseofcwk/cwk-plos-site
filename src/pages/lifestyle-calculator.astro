  }

  function buildStressSection(spd: SpeedKey): string {
    const mineCount = state.mines.length;
    const baseStress = { turtle: 5.5, car: 6.5, rocket: 8 }[spd];
    const stressSolo = Math.min(10, baseStress + mineCount * 0.5);
    const stressSupported = Math.max(2, stressSolo * 0.42);
    const soloW = Math.round(stressSolo * 10);
    const suppW = Math.round(stressSupported * 10);
    const t = SPEED_TIME_LABELS[spd];

    const burnSolo = spd === 'rocket' ? 'Very High' : spd === 'car' ? 'Moderate' : 'Low to Moderate';
    const burnSupp = spd === 'rocket' ? 'Managed' : 'Low';

    return `
      <div class="lc-stress-section">
        <div class="lc-stress-header">
          <span class="lc-res-badge">STRESS REALITY</span>
          <div class="lc-res-val lc-stress-val-head">Doing it alone vs. with the right people at the right time</div>
        </div>
        <div class="lc-stress-cols">
          <div>
            <span class="lc-stress-col-label lc-solo-label">GOING SOLO</span>
            ${stressRow('Stress level', stressSolo.toFixed(1) + '/10', soloW, 'lc-solo-fill')}
            ${stressRow('Time to goal', t.solo, Math.round(soloW * 0.75), 'lc-solo-fill')}
            ${stressRow('Risk of burnout', burnSolo, soloW - 10, 'lc-solo-fill')}
            ${stressRow('Mistake tax', 'Paid in time + money', Math.round(soloW * 0.8), 'lc-solo-fill')}
          </div>
          <div>
            <span class="lc-stress-col-label lc-supp-label">WITH RIGHT PEOPLE</span>
            ${stressRow('Stress level', stressSupported.toFixed(1) + '/10', suppW, 'lc-supp-fill')}
            ${stressRow('Time to goal', t.supported, Math.round(suppW * 0.75), 'lc-supp-fill')}
            ${stressRow('Risk of burnout', burnSupp, suppW - 5, 'lc-supp-fill')}
            ${stressRow('Mistake tax', 'Paid in investment instead', Math.round(suppW * 0.8), 'lc-supp-fill')}
          </div>
        </div>
        <div class="lc-stress-note">On average, founders working with structured mentorship and community reach their first client 2 to 3x faster and report significantly lower decision anxiety and burnout markers.</div>
      </div>`;
  }

  function stressRow(name: string, val: string, widthPct: number, fillClass: string): string {
    const w = Math.min(100, Math.max(5, widthPct));
    return `
      <div class="lc-stress-metric">
        <div class="lc-stress-metric-name">${name}</div>
        <div class="lc-stress-bar-track"><div class="lc-stress-bar-fill ${fillClass}" style="width:${w}%"></div></div>
        <div class="lc-stress-val">${val}</div>
      </div>`;
  }

  // ── Restore UI from state ──────────────────────────────
  function restoreUi(): void {
    if (state.ideaCategory) {
      const tile = document.querySelector<HTMLElement>(`.lc-cat-tile[data-cat="${state.ideaCategory}"]`);
      if (tile) {
        tile.classList.add('is-selected');
        renderSubOptions(state.ideaCategory);
      }
    }
    if (state.archetype) {
      const ac = document.querySelector(`.lc-arch-card[data-arch="${state.archetype}"]`);
      if (ac) ac.classList.add('is-selected');
    }
    if (state.speed) {
      const sc = document.querySelector(`.lc-speed-card[data-speed="${state.speed}"]`);
      if (sc) sc.classList.add('is-selected');
    }
    if (state.monthlyGoal)  (document.getElementById('lc-monthly-goal') as HTMLInputElement).value = String(state.monthlyGoal);
    if (state.offerPrice)   (document.getElementById('lc-offer-price') as HTMLInputElement).value = String(state.offerPrice);
    if (state.hoursWeek)    (document.getElementById('lc-hours-week') as HTMLInputElement).value = String(state.hoursWeek);
    if (state.timeMonths)   (document.getElementById('lc-time-months') as HTMLInputElement).value = String(state.timeMonths);
    if (state.s2l !== 1)    (document.getElementById('lc-s2l-rate') as HTMLInputElement).value = String(state.s2l);
    if (state.l2s !== 20)   (document.getElementById('lc-l2s-rate') as HTMLInputElement).value = String(state.l2s);

    state.mines.forEach((mk) => {
      const item = document.querySelector(`.lc-mine-item[data-mine="${mk}"]`);
      if (item) item.classList.add('is-selected');
    });
  }

  // ── Reset ──────────────────────────────────────────────
  function resetAll(): void {
    state = { ...initialState };
    clearState();
    document.querySelectorAll<HTMLInputElement>(
      '#lc-monthly-goal, #lc-offer-price, #lc-hours-week, #lc-time-months, #lc-s2l-rate, #lc-l2s-rate, #lc-email-input'
    ).forEach((el) => { el.value = ''; });
    document.querySelectorAll('.is-selected').forEach((el) => el.classList.remove('is-selected'));
    const sub = document.getElementById('lcSubWrap');
    if (sub) sub.setAttribute('hidden', '');
    const grid = document.getElementById('lcSubGrid');
    if (grid) grid.innerHTML = '';
    const msg = document.getElementById('lcEmailMsg');
    if (msg) msg.textContent = '';
    showStep(0);
  }

  // ── Email me my map ────────────────────────────────────
  const API_BASE = (import.meta.env.PUBLIC_API_BASE_URL ?? 'https://api.houseofcwk.com') as string;
  const EMAIL_REGEX = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  async function handleEmailSubmit(e: Event): Promise<void> {
    e.preventDefault();
    const input = document.getElementById('lc-email-input') as HTMLInputElement;
    const btn = document.getElementById('lcEmailBtn') as HTMLButtonElement;
    const msg = document.getElementById('lcEmailMsg') as HTMLElement;
    const email = input.value.trim();

    if (!EMAIL_REGEX.test(email)) {
      msg.textContent = 'Please enter a valid email address.';
      msg.dataset.tone = 'error';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Sending…';
    msg.textContent = '';

    try {
      const summary = buildEmailSummary();
      const res = await fetch(`${API_BASE}/lifestyle-calculator`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, state, summary }),
      });
      if (res.ok) {
        msg.textContent = 'Sent. Check your inbox in the next minute.';
        msg.dataset.tone = 'success';
        btn.textContent = 'Sent ✓';
      } else {
        msg.textContent = 'Something went wrong. Try again in a moment.';
        msg.dataset.tone = 'error';
        btn.disabled = false;
        btn.textContent = 'Send my map →';
      }
    } catch {
      msg.textContent = 'Network error. Please try again.';
      msg.dataset.tone = 'error';
      btn.disabled = false;
      btn.textContent = 'Send my map →';
    }
  }

  function buildEmailSummary(): {
    headline: string;
    targetLine: string;
    weeklyLine: string;
    archetype: string;
    archetypeFeeling: string;
    nextMove: string;
    speed: string;
    minesActive: number;
  } {
    const arch = getArch(state.archetype);
    const n = calcNumbers();
    const speed = SPEEDS.find((s) => s.key === state.speed);
    const subLabel = state.ideaCategory ? getSubLabel(state.ideaCategory, state.ideaType) : '';
    return {
      headline: `A ${arch ? arch.name : ''} monetizing ${subLabel || 'your edge'}, targeting $${fmtK(state.monthlyGoal)}/month.`,
      targetLine: `$${fmt(state.monthlyGoal)} per month at $${fmt(state.offerPrice)} per offer over ${state.timeMonths} months.`,
      weeklyLine: `${fmt(n.salesPw)} sales/week, ${fmt(n.leadsPw)} leads/week, ${fmt(n.strangersPw)} strangers/week.`,
      archetype: arch ? `${arch.tag} / ${arch.name}` : '',
      archetypeFeeling: arch ? arch.feeling : '',
      nextMove: arch ? arch.next : '',
      speed: speed ? `${speed.label} (${speed.time})` : '',
      minesActive: state.mines.length,
    };
  }

  // ── Wire it all up ─────────────────────────────────────
  loadState();

  document.querySelectorAll<HTMLButtonElement>('.lc-cat-tile').forEach((btn) => {
    btn.addEventListener('click', () => selectCat(btn.dataset.cat as CategoryKey, btn));
  });

  wireArchetypes();
  wireSpeeds();
  wireMines();

  document.querySelectorAll<HTMLButtonElement>('[data-next]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const step = parseInt(btn.dataset.next ?? '0', 10);
      if (validateStep(step)) showStep(step + 1);
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-back]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const step = parseInt(btn.dataset.back ?? '0', 10);
      showStep(Math.max(0, step - 1));
    });
  });

  // Live recalc on conversion-rate inputs
  ['lc-s2l-rate', 'lc-l2s-rate'].forEach((id) => {
    const el = document.getElementById(id) as HTMLInputElement | null;
    el?.addEventListener('input', () => {
      state.s2l = parseFloat((document.getElementById('lc-s2l-rate') as HTMLInputElement).value) || 1;
      state.l2s = parseFloat((document.getElementById('lc-l2s-rate') as HTMLInputElement).value) || 20;
      renderFunnel();
      saveState();
    });
  });

  document.getElementById('lcResetBtn')?.addEventListener('click', resetAll);
  document.getElementById('lcEmailForm')?.addEventListener('submit', handleEmailSubmit);

  // Restore UI from saved state, then jump to the saved step
  restoreUi();
  showStep(currentStep);
</script>

