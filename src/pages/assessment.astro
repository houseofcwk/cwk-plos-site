---
import Base from '../layouts/Base.astro';
import { QUESTIONS, ARCHETYPES, type ArchetypeKey } from '../data/assessment';

const pageTitle = 'What Player Are You? | CWK. Archetypes Assessment';
const pageDescription = 'Five questions. Under 2 min. Find out exactly which Player you are inside the CWK. world and the one move worth making this week.';

const archetypeKeys: ArchetypeKey[] = ['explorer', 'committer', 'builder', 'operator', 'sovereign'];

// Calendly URL placeholder. Swap when the real link is supplied.
const CALENDLY_URL = 'https://calendly.com/cwk-experience/intro';
---

<Base title={pageTitle} description={pageDescription}>
  <!-- ── Intro ──────────────────────────────────────────────── -->
  <section class="as-intro" data-step="intro">
    <div class="as-intro-inner">
      <span class="as-eyebrow fade-up">Archetypes Assessment</span>
      <h1 class="as-h1 fade-up fade-up-delay-1">
        Find out where you <em>actually</em> are.
      </h1>
      <p class="as-lede fade-up fade-up-delay-2">
        Five questions. Under 2 min. The result tells you which Player you are inside the CWK. world, and the one move worth making this week.
      </p>

      <ul class="as-pillars fade-up fade-up-delay-3" aria-label="Pillars covered">
        <li><span class="as-pillar-dot" style="--c:var(--pink)"></span>Soul</li>
        <li><span class="as-pillar-dot" style="--c:var(--purple)"></span>Mind</li>
        <li><span class="as-pillar-dot" style="--c:#00E396"></span>Body</li>
        <li><span class="as-pillar-dot" style="--c:#F2B53A"></span>Pocket</li>
      </ul>

      <button type="button" class="as-cta fade-up fade-up-delay-4" data-start>
        Start the journey →
      </button>

      <p class="as-fineprint fade-up fade-up-delay-4">
        No email required to see your full result.
      </p>
    </div>
  </section>

  <!-- ── Question stage ─────────────────────────────────────── -->
  <section class="as-stage" data-step="questions" hidden aria-live="polite">
    <div class="as-stage-inner">
      <div class="as-progress" aria-hidden="true">
        <div class="as-progress-meta">
          <span class="as-progress-pillar" data-progress-pillar></span>
          <span class="as-progress-num"><span data-progress-num>1</span>/{QUESTIONS.length}</span>
        </div>
        <div class="as-progress-bar"><span data-progress-bar style="width:20%"></span></div>
      </div>

      {QUESTIONS.map((q, i) => (
        <div class={`as-question ${i === 0 ? 'is-active' : ''}`} data-question={q.id} data-pillar={q.pillarLabel}>
          <h2 class="as-question-prompt">{q.prompt}</h2>
          <ul class="as-options">
            {q.options.map((opt) => (
              <li>
                <button type="button" class="as-option" data-pick={`${q.id}:${opt.letter}`}>
                  <span class="as-option-letter">{opt.letter}</span>
                  <span class="as-option-text">{opt.text}</span>
                </button>
              </li>
            ))}
          </ul>
          {i > 0 && (
            <button type="button" class="as-back" data-back>← Back</button>
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- ── Result stage ───────────────────────────────────────── -->
  <section class="as-result" data-step="result" hidden>
    <div class="as-result-inner">
      <!-- Stage progression: five dots, current one filled with archetype color -->
      <ol class="as-stage-track" aria-label="Founder progression">
        <li class="as-stage-step" data-stage="1"><span class="as-stage-dot" aria-hidden="true"></span><span class="as-stage-label">Explorer</span></li>
        <li class="as-stage-step" data-stage="2"><span class="as-stage-dot" aria-hidden="true"></span><span class="as-stage-label">Committer</span></li>
        <li class="as-stage-step" data-stage="3"><span class="as-stage-dot" aria-hidden="true"></span><span class="as-stage-label">Builder</span></li>
        <li class="as-stage-step" data-stage="4"><span class="as-stage-dot" aria-hidden="true"></span><span class="as-stage-label">Operator</span></li>
        <li class="as-stage-step" data-stage="5"><span class="as-stage-dot" aria-hidden="true"></span><span class="as-stage-label">Sovereign</span></li>
      </ol>

      <header class="as-result-head">
        <span class="as-result-icon" aria-hidden="true" data-result-icon></span>
        <span class="as-result-eyebrow" data-result-eyebrow>Stage 01</span>
        <h2 class="as-result-name">You are <span data-result-name class="as-result-name-em">Explorer</span></h2>
        <p class="as-result-tag" data-result-tag></p>
      </header>

      <aside class="as-mindset-gap" data-mindset-gap hidden>
        <span class="as-mindset-gap-tag">⚠️ Mindset gap</span>
        <p>
          Your behaviour signals the next stage but the revenue reality is not there yet. That is a diagnostic finding, not a penalty. The work right now is closing the gap, not pretending it is not there.
        </p>
      </aside>

      <div class="as-result-grid">
        <article class="as-result-block">
          <span class="as-result-block-label">What this stage feels like</span>
          <p data-result-feel></p>
        </article>
        <article class="as-result-block">
          <span class="as-result-block-label">What is actually happening</span>
          <p data-result-happening></p>
        </article>
        <article class="as-result-block">
          <span class="as-result-block-label">What is working</span>
          <p data-result-working></p>
        </article>
      </div>

      <article class="as-mind-mine">
        <span class="as-mind-mine-tag">💣 Active Mind Mine</span>
        <p data-result-mindmine></p>
      </article>

      <article class="as-environment">
        <span class="as-environment-tag">🛠 Ideal next environment</span>
        <p data-result-environment></p>
      </article>

      <article class="as-one-move">
        <span class="as-one-move-tag">⚡ The one move (this week)</span>
        <p data-result-onemove></p>
      </article>

      <div class="as-cta-block">
        <a class="as-primary-cta" data-result-cta href="#"></a>
        <div class="as-guide-cta">
          <h3>Want to speak with a qualified guide?</h3>
          <p>Twenty minutes. We look at your result together and tell you exactly what your next move should be.</p>
          <a class="as-guide-link" data-result-calendly href={CALENDLY_URL} target="_blank" rel="noopener noreferrer">Book a conversation →</a>
        </div>
      </div>

      <button type="button" class="as-restart" data-restart>↺ Restart assessment</button>
    </div>
  </section>
</Base>

<script>
  import { QUESTIONS, ARCHETYPES, score, type Letter, type ArchetypeKey } from '../data/assessment';

  type Step = 'intro' | 'questions' | 'result';
  type Answers = (Letter | null)[];

  const sections: Record<Step, HTMLElement | null> = {
    intro: document.querySelector('[data-step="intro"]'),
    questions: document.querySelector('[data-step="questions"]'),
    result: document.querySelector('[data-step="result"]'),
  };

  const questionEls = Array.from(
    document.querySelectorAll<HTMLElement>('.as-question')
  );
  const progressBar = document.querySelector<HTMLElement>('[data-progress-bar]')!;
  const progressNum = document.querySelector<HTMLElement>('[data-progress-num]')!;
  const progressPillar = document.querySelector<HTMLElement>('[data-progress-pillar]')!;

  const state: { current: number; answers: Answers } = {
    current: 0,
    answers: [null, null, null, null, null],
  };

  function show(step: Step) {
    (Object.keys(sections) as Step[]).forEach((k) => {
      const el = sections[k];
      if (!el) return;
      if (k === step) {
        el.removeAttribute('hidden');
        el.classList.add('is-active');
      } else {
        el.setAttribute('hidden', 'hidden');
        el.classList.remove('is-active');
      }
    });
    const target = sections[step];
    if (target) {
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      // Defer one frame so the section is unhidden before we scroll to it.
      requestAnimationFrame(() => {
        target.scrollIntoView({ behavior: prefersReduced ? 'auto' : 'smooth', block: 'start' });
      });
    }
  }

  function showQuestion(i: number) {
    state.current = i;
    questionEls.forEach((el, idx) => {
      el.classList.toggle('is-active', idx === i);
    });
    const pillar = QUESTIONS[i].pillarLabel;
    progressPillar.textContent = pillar;
    progressNum.textContent = String(i + 1);
    progressBar.style.width = `${((i + 1) / QUESTIONS.length) * 100}%`;

    // Keep the prompt in view as the user advances through Q1 → Q5.
    // Especially important on mobile where the new question may render below
    // the user's current scroll position.
    const stage = sections.questions;
    if (stage) {
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      stage.scrollIntoView({ behavior: prefersReduced ? 'auto' : 'smooth', block: 'start' });
    }
  }

  function chooseAnswer(qIndex: number, letter: Letter) {
    state.answers[qIndex] = letter;
    if (qIndex < QUESTIONS.length - 1) {
      showQuestion(qIndex + 1);
    } else {
      // All five answered; render result.
      const tuple = state.answers as [Letter, Letter, Letter, Letter, Letter];
      const result = score(tuple);
      renderResult(result.final, result.mindsetGap);
      show('result');
    }
  }

  function back() {
    if (state.current > 0) {
      showQuestion(state.current - 1);
    } else {
      show('intro');
    }
  }

  // Stage index per archetype, used to drive the 5-dot progression visual.
  const STAGE_INDEX: Record<ArchetypeKey, number> = {
    explorer: 1, committer: 2, builder: 3, operator: 4, sovereign: 5,
  };

  // Per-archetype glyph (inline SVG strings). Kept terse; theming lives in CSS.
  const ICONS: Record<ArchetypeKey, string> = {
    explorer:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m16.24 7.76-2.12 6.36-6.36 2.12 2.12-6.36z"/></svg>',
    committer: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 7v10l8 5 8-5V7z"/><path d="m4 7 8 5 8-5"/><path d="M12 22V12"/></svg>',
    builder:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>',
    operator:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>',
    sovereign: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 4h2l3 11h13l4-8H7"/><circle cx="9" cy="20" r="1.5"/><circle cx="18" cy="20" r="1.5"/><path d="M2 4 12 1l4 3"/></svg>',
  };

  function renderResult(key: ArchetypeKey, mindsetGap: boolean) {
    const a = ARCHETYPES[key];
    document.querySelector<HTMLElement>('[data-result-eyebrow]')!.textContent = a.eyebrow;
    document.querySelector<HTMLElement>('[data-result-name]')!.textContent = a.name;
    document.querySelector<HTMLElement>('[data-result-tag]')!.textContent = a.tagline;
    document.querySelector<HTMLElement>('[data-result-feel]')!.textContent = a.feel;
    document.querySelector<HTMLElement>('[data-result-happening]')!.textContent = a.happening;
    document.querySelector<HTMLElement>('[data-result-working]')!.textContent = a.working;
    document.querySelector<HTMLElement>('[data-result-mindmine]')!.textContent = a.mindMine;
    document.querySelector<HTMLElement>('[data-result-environment]')!.textContent = a.environment;
    document.querySelector<HTMLElement>('[data-result-onemove]')!.textContent = a.oneMove;
    const cta = document.querySelector<HTMLAnchorElement>('[data-result-cta]')!;
    cta.textContent = a.primaryCta.label;
    cta.href = a.primaryCta.href;
    const gap = document.querySelector<HTMLElement>('[data-mindset-gap]')!;
    if (mindsetGap) gap.removeAttribute('hidden');
    else gap.setAttribute('hidden', 'hidden');
    // Tag the result section with the archetype key for theming.
    sections.result?.setAttribute('data-archetype', key);

    // Inject the archetype icon.
    const iconSlot = document.querySelector<HTMLElement>('[data-result-icon]');
    if (iconSlot) iconSlot.innerHTML = ICONS[key];

    // Update progression: mark steps up to and including current as reached.
    const stage = STAGE_INDEX[key];
    document.querySelectorAll<HTMLElement>('.as-stage-step').forEach((el) => {
      const n = Number(el.dataset.stage);
      el.classList.toggle('is-current', n === stage);
      el.classList.toggle('is-reached', n <= stage);
    });
  }

  function restart() {
    state.current = 0;
    state.answers = [null, null, null, null, null];
    showQuestion(0);
    show('intro');
  }

  // Wire up
  document.querySelector<HTMLButtonElement>('[data-start]')!.addEventListener('click', () => {
    showQuestion(0);
    show('questions');
  });

  document.querySelectorAll<HTMLButtonElement>('[data-pick]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const [qid, letter] = btn.dataset.pick!.split(':') as [string, Letter];
      const idx = QUESTIONS.findIndex((q) => q.id === qid);
      if (idx < 0) return;
      chooseAnswer(idx, letter);
    });
  });

  document.querySelectorAll<HTMLButtonElement>('[data-back]').forEach((btn) => {
    btn.addEventListener('click', back);
  });

  document.querySelector<HTMLButtonElement>('[data-restart]')!.addEventListener('click', restart);

  // Initial render
  showQuestion(0);
  show('intro');
</script>

<style>
  /* ── Shared shell ───────────────────────────────────────── */
  /* Use :not([hidden]) so the HTML `hidden` attribute actually hides the
     section. Without this guard, `display: flex` would win against the UA
     `[hidden] { display: none }` rule (same specificity, author wins),
     and all three stages would stack permanently. */
  .as-intro:not([hidden]),
  .as-stage:not([hidden]),
  .as-result:not([hidden]) {
    padding: 144px 24px 96px;
    min-height: calc(100vh - 64px);
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }
  .as-intro-inner,
  .as-stage-inner,
  .as-result-inner {
    width: 100%;
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  /* ── Intro ─────────────────────────────────────────────── */
  .as-intro {
    background:
      radial-gradient(60% 50% at 50% 0%, rgba(0, 229, 255, 0.10), transparent 60%),
      radial-gradient(50% 60% at 80% 30%, rgba(123, 97, 255, 0.10), transparent 60%),
      radial-gradient(50% 60% at 20% 30%, rgba(251, 48, 121, 0.08), transparent 60%);
  }
  .as-intro-inner { align-items: center; text-align: center; gap: 16px; }
  .as-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cyan);
  }
  .as-h1 {
    margin: 0;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.03em;
    color: var(--text);
  }
  .as-h1 em {
    font-style: italic;
    background: linear-gradient(90deg, #00E5FF, #7B61FF 60%, #FB3079);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .as-lede {
    margin: 0;
    color: var(--muted);
    font-size: clamp(15px, 1.6vw, 18px);
    line-height: 1.6;
    max-width: 600px;
  }
  .as-pillars {
    margin: 12px 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .as-pillars li {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border: 1px solid var(--gb);
    border-radius: 100px;
    background: rgba(255, 255, 255, 0.02);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--muted);
  }
  .as-pillar-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--c, var(--cyan));
    box-shadow: 0 0 8px color-mix(in srgb, var(--c, var(--cyan)) 60%, transparent);
  }
  .as-cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
    padding: 16px 30px;
    border: 0;
    border-radius: 100px;
    background: linear-gradient(90deg, #00E5FF, #7B61FF);
    color: #0a0e1a;
    font: inherit;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: filter 0.2s ease, transform 0.15s ease;
  }
  .as-cta:hover { filter: brightness(1.1); transform: translateY(-1px); }
  .as-fineprint {
    margin: 0;
    font-size: 12px;
    color: var(--dim);
  }

  /* ── Questions ─────────────────────────────────────────── */
  .as-progress {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 18px;
  }
  .as-progress-meta {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--dim);
    font-weight: 700;
  }
  .as-progress-pillar { color: var(--cyan); }
  .as-progress-bar {
    height: 4px;
    background: rgba(255, 255, 255, 0.06);
    border-radius: 100px;
    overflow: hidden;
  }
  .as-progress-bar > span {
    display: block;
    height: 100%;
    background: linear-gradient(90deg, #00E5FF, #7B61FF);
    transition: width 0.4s ease;
  }

  .as-question {
    display: none;
    flex-direction: column;
    gap: 22px;
    animation: as-fade 0.35s ease both;
  }
  .as-question.is-active { display: flex; }
  @keyframes as-fade {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .as-question-prompt {
    margin: 0 0 4px;
    font-size: clamp(24px, 3vw, 34px);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.22;
    color: var(--text);
    max-width: 720px;
  }

  .as-options {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .as-option {
    display: flex;
    align-items: center;
    gap: 16px;
    width: 100%;
    min-height: 64px;
    padding: 18px 22px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.025);
    color: var(--text);
    font: inherit;
    text-align: left;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition:
      border-color 0.2s ease,
      background 0.2s ease,
      transform 0.15s ease,
      box-shadow 0.2s ease;
  }
  /* Disable hover translate on touch — feels jittery on mobile */
  @media (hover: none) {
    .as-option:hover { transform: none; }
  }
  .as-option:active {
    transform: scale(0.985);
  }
  .as-option-letter {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.16);
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: rgba(255, 255, 255, 0.85);
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  .as-option-text {
    flex: 1;
    font-size: 15.5px;
    font-weight: 500;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.92);
    letter-spacing: -0.005em;
  }
  .as-option:hover {
    border-color: rgba(0, 229, 255, 0.55);
    background: rgba(0, 229, 255, 0.06);
    box-shadow: 0 6px 24px rgba(0, 229, 255, 0.10);
    transform: translateX(4px);
  }
  .as-option:hover .as-option-letter {
    color: #07090F;
    background: var(--cyan);
    border-color: var(--cyan);
  }
  .as-option:hover .as-option-text { color: var(--text); }
  .as-option:focus-visible {
    outline: 2px solid var(--cyan);
    outline-offset: 3px;
  }

  .as-back {
    align-self: flex-start;
    margin-top: 4px;
    min-height: 44px;
    padding: 10px 18px;
    background: transparent;
    border: 1px solid var(--gb);
    border-radius: 100px;
    color: var(--dim);
    font: inherit;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .as-back:hover { color: var(--text); border-color: var(--gb2); }

  /* ── Result ────────────────────────────────────────────── */
  /* Per-archetype theme tokens. --as-accent is the saturated brand color
     used for buttons and dots. --as-accent-text is a lighter shade used
     for label text where the saturated tone would be too hard to read on
     dark. Every accent below references these tokens so the result stays
     visually coherent with the archetype the user landed on. */
  .as-result {
    --as-accent: #00E5FF;
