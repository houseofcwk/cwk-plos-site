---
import Base from '../../layouts/Base.astro';
import BrandMirrorQuiz from '../../components/BrandMirrorQuiz';
---

<Base title="Brand Mirror Quiz — CWK. Experience" description="Take the 4-question Brand Mirror to see where your business infrastructure is leaking.">
  <section class="quiz-page">
    <div class="quiz-inner">
      <BrandMirrorQuiz client:visible />
    </div>
  </section>
</Base>

<style>
  .quiz-page { padding-top: 120px; padding-bottom: 80px; min-height: 100vh; }
  .quiz-inner { max-width: 640px; margin: 0 auto; padding: 0 24px; }
</style>
