---
import Base from '../../layouts/Base.astro';
---

<Base
  title="Brand Mirror — CWK. Experience"
  description="See where your brand is leaking in 2 minutes. Free, no email required."
>
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <span class="eyebrow fade-up">The Brand Mirror</span>
      <h1 class="hero-headline fade-up fade-up-delay-1">
        See where your brand is leaking.
      </h1>
      <p class="hero-sub fade-up fade-up-delay-2">
        2 minutes. Free. No email required.
      </p>
      <div class="hero-cta fade-up fade-up-delay-3">
        <a href="/brand-mirror/quiz" class="btn btn-gradient">See Your Reflection →</a>
      </div>
    </div>
  </section>

  <!-- ── How it works ──────────────────────────────────────── -->
  <section class="section how-it-works">
    <div class="section-inner">
      <span class="eyebrow">How It Works</span>
      <h2>Three steps to clarity.</h2>

      <div class="steps-grid">
        <div class="step-card glass-card fade-up">
          <span class="step-number">01</span>
          <h3>4 Questions</h3>
          <p>Answer four focused questions about your business, revenue, systems, and team.</p>
        </div>
        <div class="step-card glass-card fade-up fade-up-delay-1">
          <span class="step-number">02</span>
          <h3>See Your Bottleneck</h3>
          <p>Instantly surface the single constraint that's capping your growth right now.</p>
        </div>
        <div class="step-card glass-card fade-up fade-up-delay-2">
          <span class="step-number">03</span>
          <h3>Get a Plan</h3>
          <p>Walk away with a clear picture of what to fix and how CWK. can install it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Guarantee bar ─────────────────────────────────────── -->
  <section class="section guarantee">
    <div class="section-inner">
      <div class="guarantee-bar glass-card">
        <p class="guarantee-text">No email. No sales pitch. Just clarity.</p>
      </div>
    </div>
  </section>

  <!-- ── Second CTA ────────────────────────────────────────── -->
  <section class="section second-cta">
    <div class="section-inner">
      <a href="/brand-mirror/quiz" class="btn btn-primary">Start the Brand Mirror →</a>
    </div>
  </section>
</Base>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .hero {
    padding-top: 144px;
    padding-bottom: 80px;
    padding-left: 24px;
    padding-right: 24px;
    text-align: center;
  }

  .hero-inner {
    max-width: 680px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .hero-inner .eyebrow {
    margin-bottom: 16px;
  }

  .hero-headline {
    font-size: clamp(38px, 6vw, 58px);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-bottom: 20px;
  }

  .hero-sub {
    font-size: 18px;
    color: var(--muted);
    margin-bottom: 36px;
    letter-spacing: 0.01em;
  }

  .hero-cta {
    margin-top: 8px;
  }

  .hero-cta .btn {
    font-size: 15px;
    padding: 14px 32px;
  }

  /* ── How it works ─────────────────────────────────── */
  .how-it-works h2 {
    margin-bottom: 32px;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gap-tile);
  }

  .step-card {
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .step-number {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--cyan);
    opacity: 0.7;
  }

  .step-card h3 {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
  }

  .step-card p {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
  }

  /* ── Guarantee bar ────────────────────────────────── */
  .guarantee-bar {
    padding: 28px 40px;
    text-align: center;
  }

  .guarantee-text {
    font-size: 16px;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0.01em;
  }

  /* ── Second CTA ───────────────────────────────────── */
  .second-cta .section-inner {
    display: flex;
    justify-content: center;
    padding-bottom: 40px;
  }

  .second-cta .btn {
    font-size: 15px;
    padding: 14px 32px;
  }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 768px) {
    .steps-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding-top: 112px;
    }

    .guarantee-bar {
      padding: 22px 20px;
    }
  }
</style>
