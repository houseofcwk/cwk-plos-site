---
import Base from '../../layouts/Base.astro';
import PortableText from '../../components/PortableText.astro';
import { sanity } from '../../lib/sanity';
import { JOURNEY_QUERY } from '../../lib/queries';

let s: any = null;
try { s = await sanity.fetch(JOURNEY_QUERY); } catch { s = null; }

const heroEyebrow  = s?.heroEyebrow  ?? 'The Journey';
const heroHeadline = s?.heroHeadline ?? 'Chapter by chapter.';

const pageTitle = s?.seo?.title ?? "Kris's Journey | CWK. Experience";
const pageDescription = s?.seo?.description ?? 'From Caguas, Puerto Rico to Austin, TX: the chapter-by-chapter story of Kris San, founder of CWK. Experience.';
---

<Base
  title={pageTitle}
  description={pageDescription}
>
  <!-- ── Hero ─────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-inner">
      <a href="/about" class="back-link">← Back to About</a>
      <span class="eyebrow fade-up">{heroEyebrow}</span>
      <h1 class="hero-headline fade-up fade-up-delay-1">{heroHeadline}</h1>
    </div>
  </section>

  {s?.body ? (
    <!-- ── Sanity-authored body ───────────────────────────── -->
    <section class="section body-section">
      <div class="section-inner">
        <div class="pt-body"><PortableText value={s.body} /></div>
      </div>
    </section>
  ) : (
  <>
  <!-- ── Timeline ──────────────────────────────────────────── -->
  <section class="section timeline-section">
    <div class="section-inner">
      <div class="timeline">

        <!-- Chapter 1 -->
        <div class="timeline-item">
          <div class="timeline-connector">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>
          <div class="chapter-card glass-card">
            <span class="eyebrow">Chapter 1</span>
            <h2 class="chapter-heading">Puerto Rico</h2>
            <p class="chapter-body">I was raised in Caguas, Puerto Rico.</p>
          </div>
        </div>

        <!-- Chapter 2 -->
        <div class="timeline-item">
          <div class="timeline-connector">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>
          <div class="chapter-card glass-card">
            <span class="eyebrow">Chapter 2</span>
            <h2 class="chapter-heading">Leaving Puerto Rico <span class="chapter-year">2010</span></h2>
            <p class="chapter-body">Arrived in Austin, TX alone without knowing anyone. I was so lost.</p>
          </div>
        </div>

        <!-- Chapter 3 -->
        <div class="timeline-item">
          <div class="timeline-connector">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>
          <div class="chapter-card glass-card">
            <span class="eyebrow">Chapter 3</span>
            <h2 class="chapter-heading">Waking Up <span class="chapter-year">2015</span></h2>
            <p class="chapter-body">My living on purpose clock started in 2015 when I founded my first business KSSO.</p>
          </div>
        </div>

        <!-- Chapter 4 -->
        <div class="timeline-item">
          <div class="timeline-connector">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>
          <div class="chapter-card glass-card">
            <span class="eyebrow">Chapter 4</span>
            <h2 class="chapter-heading">Picking a Direction <span class="chapter-year">2019</span></h2>
            <p class="chapter-body">It was time to start building a cohesive body of work.</p>
          </div>
        </div>

        <!-- Chapter 5 -->
        <div class="timeline-item">
          <div class="timeline-connector">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>
          <div class="chapter-card glass-card">
            <span class="eyebrow">Chapter 5</span>
            <h2 class="chapter-heading">Building the Body of Work <span class="chapter-year">2019 – 2025</span></h2>
            <p class="chapter-body">I've stayed in constant motion. Learning &amp; Earning.</p>
          </div>
        </div>

        <!-- Chapter 6 -->
        <div class="timeline-item timeline-item-last">
          <div class="timeline-connector">
            <div class="timeline-dot timeline-dot-active"></div>
          </div>
          <div class="chapter-card glass-card chapter-card-active">
            <span class="eyebrow">Chapter 6</span>
            <h2 class="chapter-heading">In Progress <span class="chapter-year chapter-year-live">Now</span></h2>
            <p class="chapter-body">The story is still being written.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────── -->
  <section class="section cta-section">
    <div class="section-inner">
      <div class="cta-block glass-card">
        <span class="eyebrow">The Work</span>
        <h2>See what this journey produced.</h2>
        <p>Every chapter built the foundation for what CWK. does for clients today.</p>
        <a href="/work" class="btn btn-primary">See The Work →</a>
      </div>
    </div>
  </section>
  </>
  )}
</Base>

<style>
  /* ── Hero ─────────────────────────────────────────── */
  .hero {
    padding-top: 144px;
    padding-bottom: 64px;
    padding-left: 24px;
    padding-right: 24px;
    text-align: center;
  }

  .hero-inner {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .back-link {
    display: inline-block;
    font-size: 13px;
    color: var(--dim);
    text-decoration: none;
    letter-spacing: 0.04em;
    margin-bottom: 32px;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--cyan);
  }

  .hero-inner .eyebrow {
    margin-bottom: 16px;
  }

  .hero-headline {
    font-size: clamp(40px, 7vw, 72px);
    font-weight: 800;
    line-height: 1.0;
    letter-spacing: -0.04em;
    color: var(--text);
    margin: 0;
  }

  /* ── Timeline ─────────────────────────────────────── */
  .timeline-section .section-inner {
    max-width: 680px;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 32px 1fr;
    gap: 0 20px;
  }

  .timeline-item-last .timeline-connector {
    justify-content: flex-start;
  }

  .timeline-connector {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .timeline-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--cyan);
    flex-shrink: 0;
    margin-top: 28px;
    box-shadow: 0 0 10px rgba(0, 229, 255, 0.4);
  }

  .timeline-dot-active {
    width: 14px;
    height: 14px;
    background: var(--cyan);
    box-shadow: 0 0 16px rgba(0, 229, 255, 0.7), 0 0 32px rgba(0, 229, 255, 0.3);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 16px rgba(0, 229, 255, 0.7), 0 0 32px rgba(0, 229, 255, 0.3); }
    50% { box-shadow: 0 0 24px rgba(0, 229, 255, 0.9), 0 0 48px rgba(0, 229, 255, 0.5); }
  }

  .timeline-line {
    width: 1px;
    flex: 1;
    background: linear-gradient(to bottom, var(--cyan), rgba(0, 229, 255, 0.1));
    margin-top: 8px;
    margin-bottom: 0;
    min-height: 24px;
  }

  .chapter-card {
    padding: var(--pad-md);
    margin-bottom: var(--gap-tile);
    border-left: 2px solid var(--cyan);
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .chapter-card-active {
    border-left-color: var(--cyan);
    background: rgba(0, 229, 255, 0.04);
  }

  .chapter-card .eyebrow {
    margin-bottom: 4px;
  }

  .chapter-heading {
    font-size: clamp(18px, 2.5vw, 22px);
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
    display: flex;
    align-items: baseline;
    gap: 12px;
    flex-wrap: wrap;
  }

  .chapter-year {
    font-size: 13px;
    font-weight: 500;
    color: var(--dim);
    letter-spacing: 0.02em;
  }

  .chapter-year-live {
    color: var(--cyan);
    font-weight: 600;
  }

  .chapter-body {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.65;
    margin: 0;
  }

  /* ── CTA Block ────────────────────────────────────── */
  .cta-block {
    padding: 48px var(--pad-lg);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    max-width: 680px;
    margin: 0 auto;
  }

  .cta-block .eyebrow {
    margin-bottom: 4px;
  }

  .cta-block h2 {
    font-size: clamp(20px, 3vw, 28px);
    font-weight: 700;
    color: var(--text);
    line-height: 1.2;
    margin: 0;
  }

  .cta-block p {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.6;
    max-width: 400px;
    margin: 0 0 8px;
  }

  /* ── Portable Text body (Sanity-authored) ─────────── */
  .body-section .section-inner {
    max-width: 680px;
  }
  .pt-body :global(h2) {
    font-size: clamp(20px, 2.8vw, 26px);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
    margin: 32px 0 12px;
  }
  .pt-body :global(h2:first-child) { margin-top: 0; }
  .pt-body :global(h3) {
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    margin: 24px 0 10px;
  }
  .pt-body :global(p) {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.7;
    margin: 0 0 14px;
  }
  .pt-body :global(ul) {
    list-style: none;
    padding-left: 0;
    margin: 0 0 14px;
  }
  .pt-body :global(li) {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.65;
    padding-left: 20px;
    position: relative;
    margin-bottom: 8px;
  }
  .pt-body :global(li::before) {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--cyan);
    font-size: 11px;
    top: 3px;
  }
  .pt-body :global(strong) { color: var(--text); font-weight: 600; }
  .pt-body :global(a)      { color: var(--cyan); }

  /* ── Responsive ───────────────────────────────────── */
  @media (max-width: 640px) {
    .hero {
      padding-top: 112px;
      padding-bottom: 48px;
    }

    .chapter-card {
      padding: var(--pad-md) 16px;
    }

    .cta-block {
      padding: 32px 24px;
    }
  }
</style>
