---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WaitlistModal from '../components/WaitlistModal';
import '../styles/global.css';
import { getSiteSettings } from '../lib/sanity';
import { ORGANIZATION_FALLBACK, TWITTER_HANDLE } from '../lib/seoFallbacks';

interface Props {
  title: string;
  description: string;
  ogImage?: string | null;
  ogImageAlt?: string | null;
  canonical?: string | null;
  ogType?: string | null;
  twitterCard?: string | null;
  robots?: string | null;
  /** Optional extra JSON-LD blocks injected per page (FAQPage, Article, etc.). */
  extraJsonLd?: object | object[] | null;
}

const {
  title,
  description,
  ogImage,
  ogImageAlt,
  canonical,
  ogType,
  twitterCard,
  robots,
  extraJsonLd,
} = Astro.props;

const analyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
const gtmId = import.meta.env.PUBLIC_GTM_ID;

// Site settings drive twitter handle, default OG image, and Organization JSON-LD.
// getSiteSettings is memoized + crash-safe; null when Sanity is empty/down.
const settings = await getSiteSettings();

const twitterHandle = settings?.twitterHandle ?? TWITTER_HANDLE;
const defaultOgImage =
  ogImage ?? settings?.defaultSeo?.ogImage?.asset?.url ?? null;
const defaultOgImageAlt =
  ogImageAlt ?? settings?.defaultSeo?.ogImage?.alt ?? null;

// Merge Sanity organization fields over hardcoded fallback so missing fields
// never produce empty JSON-LD values.
const org = settings?.organization ?? null;
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: org?.name ?? ORGANIZATION_FALLBACK.name,
  alternateName: org?.alternateName ?? ORGANIZATION_FALLBACK.alternateName,
  url: ORGANIZATION_FALLBACK.url,
  logo: ORGANIZATION_FALLBACK.logo,
  description: org?.description ?? ORGANIZATION_FALLBACK.description,
  slogan: org?.slogan ?? ORGANIZATION_FALLBACK.slogan,
  foundingDate: org?.foundingDate ?? ORGANIZATION_FALLBACK.foundingDate,
  founder: {
    '@type': 'Person',
    name: org?.founderName ?? ORGANIZATION_FALLBACK.founder.name,
    jobTitle: org?.founderJobTitle ?? ORGANIZATION_FALLBACK.founder.jobTitle,
    sameAs:
      Array.isArray(org?.founderSameAs) && org.founderSameAs.length > 0
        ? org.founderSameAs
        : ORGANIZATION_FALLBACK.founder.sameAs,
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: org?.addressLocality ?? ORGANIZATION_FALLBACK.address.addressLocality,
    addressRegion: org?.addressRegion ?? ORGANIZATION_FALLBACK.address.addressRegion,
    addressCountry: org?.addressCountry ?? ORGANIZATION_FALLBACK.address.addressCountry,
  },
  areaServed: org?.areaServed ?? ORGANIZATION_FALLBACK.areaServed,
  knowsAbout:
    Array.isArray(org?.knowsAbout) && org.knowsAbout.length > 0
      ? org.knowsAbout
      : ORGANIZATION_FALLBACK.knowsAbout,
};

const extraBlocks = extraJsonLd
  ? Array.isArray(extraJsonLd)
    ? extraJsonLd
    : [extraJsonLd]
  : [];
---

<!doctype html>
<html lang="en">
  <head>
    {gtmId && (
      <script is:inline define:vars={{ gtmId }}>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer',gtmId);
      </script>
    )}
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#07090F" />
    <SEO
      title={title}
      description={description}
      ogImage={defaultOgImage}
      ogImageAlt={defaultOgImageAlt}
      canonical={canonical}
      ogType={ogType}
      twitterCard={twitterCard}
      twitterHandle={twitterHandle}
      robots={robots}
    />

    <!-- JSON-LD: Organization (site-wide) -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(organizationJsonLd)}
    />
    {extraBlocks.map((block) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}

    {analyticsToken && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${analyticsToken}"}`}
      />
    )}
  </head>
  <body>
    {gtmId && (
      <noscript><iframe src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`}
      height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    )}
    <!-- Ambient orb: cyan -->
    <div class="orb orb-cyan" aria-hidden="true"></div>
    <!-- Ambient orb: purple -->
    <div class="orb orb-purple" aria-hidden="true"></div>

    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <WaitlistModal client:load />

    <script>
      /* Reveal-on-scroll: toggles .is-visible on any .reveal-card / .reveal-up */
      (() => {
        const targets = document.querySelectorAll<HTMLElement>('.reveal-card, .reveal-up');
        if (!targets.length) return;

        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduced || !('IntersectionObserver' in window)) {
          targets.forEach(el => el.classList.add('is-visible'));
          return;
        }

        const io = new IntersectionObserver((entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          }
        }, { rootMargin: '0px 0px -10% 0px', threshold: 0.12 });

        targets.forEach(el => io.observe(el));
      })();
    </script>
  </body>
</html>

<style is:global>
  .orb {
    position: fixed;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
    filter: blur(140px);
  }

  .orb-cyan {
    width: 600px;
    height: 600px;
    top: -200px;
    left: -200px;
    background: rgba(0, 229, 255, 0.04);
  }

  .orb-purple {
    width: 500px;
    height: 500px;
    bottom: -100px;
    right: -100px;
    background: rgba(123, 97, 255, 0.05);
  }

  main {
    position: relative;
    z-index: 1;
    padding-bottom: 80px;
  }
</style>
