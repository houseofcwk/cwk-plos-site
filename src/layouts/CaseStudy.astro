---
import Base from './Base.astro';
import WaitlistForm from '../components/WaitlistForm';

interface Props {
  title: string;
  description: string;
  category: string;
  client: string;
  headline: string;
  duration?: string;
  result?: string;
  resultLabel?: string;
}

const { title, description, category, client, headline, duration, result, resultLabel } = Astro.props;
---

<Base title={`${client} — CWK. Work`} description={description}>

  <!-- ── Case Study Hero ── -->
  <section class="cs-hero">
    <div class="cs-hero-inner">
      <a href="/work" class="back-link">← All Work</a>
      <span class="eyebrow">{category}</span>
      <h1 class="cs-headline fade-up">{headline}</h1>
      <div class="cs-meta fade-up">
        <span class="cs-client">{client}</span>
        {duration && <><span class="cs-sep">·</span><span class="cs-duration">{duration}</span></>}
        {result && resultLabel && (
          <><span class="cs-sep">·</span>
          <span class="cs-result-pill">
            <span class="cs-result-num">{result}</span>
            <span class="cs-result-lbl">{resultLabel}</span>
          </span></>
        )}
      </div>
    </div>
  </section>

  <!-- ── Case Study Body ── -->
  <article class="cs-body">
    <div class="cs-body-inner">
      <slot />
    </div>
  </article>

  <!-- ── Back to Work ── -->
  <section class="cs-footer-nav section">
    <div class="section-inner">
      <a href="/work" class="btn btn-ghost">← Back to All Work</a>
    </div>
  </section>

  <!-- ── Waitlist CTA ── -->
  <section id="waitlist" class="section waitlist-section">
    <div class="section-inner">
      <span class="eyebrow">Early Access</span>
      <h2>Ready to build infrastructure like this for your business?</h2>
      <p class="section-sub">Join the waitlist for CWK. Agent+ — the operating system that manages your growth across Mind, Body, Soul, and Pocket.</p>
      <WaitlistForm client:visible />
    </div>
  </section>

</Base>

<style>
  /* ── Hero ── */
  .cs-hero {
    padding-top: 120px;
    padding-bottom: 60px;
    padding-left: 24px;
    padding-right: 24px;
    border-bottom: 1px solid var(--gb);
  }

  .cs-hero-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .back-link {
    font-size: 13px;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 8px;
  }
  .back-link:hover { color: var(--cyan); }

  .cs-headline {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: var(--text);
    margin-top: 8px;
  }

  .cs-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }

  .cs-client {
    font-size: 14px;
    font-weight: 600;
    color: var(--cyan);
  }

  .cs-sep {
    color: var(--dim);
    font-size: 14px;
  }

  .cs-duration {
    font-size: 13px;
    color: var(--muted);
  }

  .cs-result-pill {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    background: rgba(0, 229, 255, 0.08);
    border: 1px solid rgba(0, 229, 255, 0.18);
    border-radius: 40px;
    padding: 3px 12px;
  }

  .cs-result-num {
    font-size: 14px;
    font-weight: 800;
    background: linear-gradient(135deg, #00E5FF, #7B61FF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cs-result-lbl {
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ── Body ── */
  .cs-body {
    padding: 64px 24px;
  }

  .cs-body-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  /* Prose defaults for slotted content */
  .cs-body-inner :global(h2) {
    font-size: clamp(20px, 2.5vw, 26px);
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--gb);
  }

  .cs-body-inner :global(h3) {
    font-size: 17px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 12px;
  }

  .cs-body-inner :global(p) {
    font-size: 16px;
    line-height: 1.7;
    color: var(--muted);
  }

  .cs-body-inner :global(ul) {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-left: 20px;
  }

  .cs-body-inner :global(li) {
    font-size: 15px;
    line-height: 1.6;
    color: var(--muted);
  }

  .cs-body-inner :global(strong) {
    color: var(--text);
    font-weight: 600;
  }

  .cs-body-inner :global(a) {
    color: var(--cyan);
    text-decoration: none;
  }
  .cs-body-inner :global(a:hover) { text-decoration: underline; }

  /* ── Glass section ── */
  .cs-body-inner :global(.cs-section) {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── YouTube embed ── */
  .cs-body-inner :global(.yt-embed) {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    border-radius: 12px;
    overflow: hidden;
    background: var(--bg2);
    border: 1px solid var(--gb);
  }

  .cs-body-inner :global(.yt-embed iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ── Stats row ── */
  .cs-body-inner :global(.cs-stats) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gap-tile);
  }

  .cs-body-inner :global(.cs-stat) {
    background: var(--glass);
    border: 1px solid var(--gb);
    border-radius: 12px;
    padding: 20px 16px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .cs-body-inner :global(.cs-stat-num) {
    font-size: 24px;
    font-weight: 800;
    background: linear-gradient(135deg, #00E5FF, #7B61FF);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cs-body-inner :global(.cs-stat-label) {
    font-size: 11px;
    color: var(--dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* ── Back nav ── */
  .cs-footer-nav {
    padding-top: 0;
    padding-bottom: 0;
  }

  /* ── Waitlist ── */
  .waitlist-section {
    text-align: center;
    border-top: 1px solid var(--gb);
  }
  .waitlist-section h2 {
    font-size: clamp(20px, 3vw, 30px);
    margin-bottom: 12px;
  }
  .waitlist-section .section-sub {
    max-width: 480px;
    margin: 0 auto 32px;
  }

  @media (max-width: 640px) {
    .cs-hero { padding-top: 100px; }
    .cs-body-inner :global(.cs-stats) { grid-template-columns: 1fr; }
  }
</style>
