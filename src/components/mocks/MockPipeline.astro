---
---
<div class="mock-pipeline">
  <!-- Summary bar -->
  <div class="pipeline-summary">
    <span class="pipeline-summary-text">6 open deals</span>
    <span class="pipeline-dot"></span>
    <span class="pipeline-summary-value">$42,000 pipeline</span>
  </div>

  <!-- Kanban columns -->
  <div class="pipeline-cols">
    <div class="pipeline-col">
      <span class="col-label">Aware</span>
      <div class="deal-card">
        <span class="deal-name">Rivera Media</span>
        <span class="deal-type">Brand Mgmt</span>
        <div class="deal-meta">
          <span class="deal-value">$8,000</span>
          <span class="deal-days">4d</span>
        </div>
      </div>
      <div class="deal-card">
        <span class="deal-name">Founders Forum</span>
        <span class="deal-type">Advisory</span>
        <div class="deal-meta">
          <span class="deal-value">$3,500</span>
          <span class="deal-days">2d</span>
        </div>
      </div>
    </div>

    <div class="pipeline-col">
      <span class="col-label">Engaged</span>
      <div class="deal-card">
        <span class="deal-name">TechScale Inc.</span>
        <span class="deal-type">Full Service</span>
        <div class="deal-meta">
          <span class="deal-value">$18,000</span>
          <span class="deal-days">9d</span>
        </div>
      </div>
    </div>

    <div class="pipeline-col">
      <span class="col-label">Active</span>
      <div class="deal-card stalled">
        <span class="deal-name">Atlas Creative</span>
        <span class="deal-type">Content Ops</span>
        <div class="deal-meta">
          <span class="deal-value">$12,500</span>
          <span class="deal-days stalled-days">16d</span>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  .mock-pipeline {
    background: var(--bg2);
    border: 1px solid var(--gb);
    border-radius: var(--radius-card);
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-family: var(--font-primary);
  }

  .pipeline-summary {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    background: var(--glass);
    border: 1px solid var(--gb);
    border-radius: 8px;
  }

  .pipeline-summary-text { font-size: 11px; color: var(--muted); }

  .pipeline-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--dim);
  }

  .pipeline-summary-value {
    font-size: 11px;
    font-weight: 700;
    color: var(--cyan);
  }

  .pipeline-cols {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  .pipeline-col {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .col-label {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dim);
    padding: 0 4px;
  }

  .deal-card {
    background: var(--bg3);
    border: 1px solid var(--gb);
    border-radius: 8px;
    padding: 9px 10px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .deal-card.stalled {
    border-color: rgba(255, 68, 68, 0.35);
  }

  .deal-name {
    font-size: 11px;
    font-weight: 600;
    color: var(--text);
  }

  .deal-type {
    font-size: 9px;
    color: var(--dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .deal-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 5px;
    padding-top: 5px;
    border-top: 1px solid var(--gb);
  }

  .deal-value {
    font-size: 11px;
    font-weight: 700;
    color: var(--stage-6);
  }

  .deal-days {
    font-size: 9px;
    color: var(--dim);
  }

  .deal-days.stalled-days {
    color: var(--stage-1);
    font-weight: 700;
  }
</style>
