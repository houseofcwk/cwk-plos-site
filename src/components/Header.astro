---
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || currentPath.startsWith(path + '/');
---

<header class="site-header">
  <nav class="nav-inner">
    <a href="/" class="logo" aria-label="CWK. Experience — Home">CWK.</a>

    <div class="nav-links">
      <a href="/product" class:list={['nav-link', { active: isActive('/product') }]}>Product</a>
      <a href="/work"    class:list={['nav-link', { active: isActive('/work') }]}>Work</a>
      <a href="/about"   class:list={['nav-link', { active: isActive('/about') }]}>About</a>
    </div>

    <a href="/brand-mirror" class="btn btn-primary nav-cta">
      Brand Mirror →
    </a>

    <!-- Mobile hamburger -->
    <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </nav>

  <!-- Mobile overlay menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <a href="/product"      class="mobile-link">Product</a>
    <a href="/work"         class="mobile-link">Work</a>
    <a href="/about"        class="mobile-link">About</a>
    <a href="/brand-mirror" class="mobile-link">Brand Mirror</a>
    <a href="/side-quests"  class="mobile-link">Side Quests</a>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(7, 9, 15, 0.85);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--gb);
    height: 64px;
  }

  .nav-inner {
    display: flex;
    align-items: center;
    gap: 32px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    height: 100%;
  }

  .logo {
    font-size: 18px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.03em;
    text-decoration: none;
    flex-shrink: 0;
  }
  .logo:hover { color: var(--cyan); }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
    flex: 1;
  }

  .nav-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease;
    padding: 4px 0;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
  }

  .nav-cta {
    margin-left: auto;
    flex-shrink: 0;
    padding: 8px 18px;
    font-size: 13px;
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: auto;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: all 0.2s ease;
  }

  /* Mobile menu overlay */
  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: var(--gap-tile);
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--bg);
    padding: 32px 24px;
    z-index: 99;
  }

  .mobile-menu.open {
    display: flex;
  }

  .mobile-link {
    font-size: 24px;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    padding: 16px 0;
    border-bottom: 1px solid var(--gb);
  }
  .mobile-link:hover { color: var(--cyan); }

  @media (max-width: 768px) {
    .nav-links,
    .nav-cta {
      display: none;
    }
    .hamburger {
      display: flex;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
  });
</script>
