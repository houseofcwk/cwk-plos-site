<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo">CWK.</a>
        <p class="footer-tagline">CWK. gamifies your growth across Mind, Body, Soul, and Pocket.</p>
      </div>

      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-col">
          <span class="footer-col-title">Platform</span>
          <a href="/product">Agent+</a>
          <a href="/assessment">What Player Are You?</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-title">Work</span>
          <a href="/case-studies">Case Studies</a>
          <a href="/side-quests">Side Quests</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-title">Company</span>
          <a href="/about">About Kris</a>
          <a href="/contact">Contact</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-title">Legal</span>
          <a href="/privacy">Privacy</a>
          <a href="/terms">Terms</a>
        </div>
      </nav>
    </div>

    <div class="footer-bottom">
      <span class="footer-copy">© 2026 CWK. LLC · Build. Learn. Earn. Play.</span>
      <span class="footer-confidential">Confidential</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--gb);
    margin-top: 80px;
    padding: 56px 24px 32px;
  }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .footer-top {
    display: flex;
    gap: 64px;
    align-items: flex-start;
  }

  .footer-brand {
    flex: 0 0 220px;
  }

  .footer-logo {
    display: inline-block;
    font-size: 20px;
    font-weight: 800;
    color: var(--text);
    text-decoration: none;
    letter-spacing: -0.03em;
    margin-bottom: 12px;
  }
  .footer-logo:hover { color: var(--cyan); }

  .footer-tagline {
    font-size: 13px;
    color: var(--dim);
    line-height: 1.5;
  }

  .footer-nav {
    display: flex;
    gap: 48px;
    flex: 1;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-col-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--dim);
    margin-bottom: 4px;
  }

  .footer-col a {
    font-size: 14px;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .footer-col a:hover { color: var(--text); }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 24px;
    border-top: 1px solid var(--gb);
  }

  .footer-copy {
    font-size: 12px;
    color: var(--dim);
  }

  .footer-confidential {
    font-size: 11px;
    color: var(--dim);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .footer-top {
      flex-direction: column;
      gap: 32px;
    }
    .footer-brand { flex: none; }
    .footer-nav { flex-wrap: wrap; gap: 32px; }
    .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
  }
</style>
