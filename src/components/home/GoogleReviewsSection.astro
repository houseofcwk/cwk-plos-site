---
export interface CuratedReview {
  author: string;
  rating: number;
  text: string;
  relativeTime?: string | null;
  authorUrl?: string | null;
  profilePhotoUrl?: string | null;
}

interface Props {
  reviews?: CuratedReview[] | null;
  aggregateRating?: number | null;
  totalCount?: number | null;
}

const { reviews, aggregateRating, totalCount } = Astro.props;

const list = (reviews ?? []).filter((r) => r && r.author && r.text).slice(0, 6);
const REVIEW_URL = 'https://maps.app.goo.gl/NWYxzWR38jGLfsNU7';

const renderStars = (n: number) => {
  const full = Math.round(Math.max(0, Math.min(5, n)));
  return '★★★★★☆☆☆☆☆'.slice(5 - full, 10 - full);
};

const initials = (name: string) =>
  name
    .split(/\s+/)
    .filter(Boolean)
    .slice(0, 2)
    .map((s) => s[0]!.toUpperCase())
    .join('');

const showHeaderMeta =
  typeof aggregateRating === 'number' && aggregateRating > 0 && typeof totalCount === 'number' && totalCount > 0;
---

{list.length > 0 && (
  <section class="section reviews-section" aria-labelledby="reviews-heading">
    <div class="section-inner">
      <header class="reviews-header">
        <span class="pill-eyebrow reveal-up">
          <span class="pill-dot" aria-hidden="true"></span>
          From Google
        </span>
        <h2 id="reviews-heading" class="reviews-title reveal-up reveal-delay-1">
          What founders say about CWK.
        </h2>
        {showHeaderMeta && (
          <div class="reviews-meta reveal-up reveal-delay-2">
            <span class="reviews-stars" aria-hidden="true">{renderStars(aggregateRating!)}</span>
            <span class="reviews-rating">{aggregateRating!.toFixed(1)}</span>
            <span class="reviews-count">({totalCount!.toLocaleString()} Google reviews)</span>
            <a class="reviews-link" href={REVIEW_URL} target="_blank" rel="noopener noreferrer">View on Google</a>
          </div>
        )}
        {!showHeaderMeta && (
          <div class="reviews-meta reveal-up reveal-delay-2">
            <a class="reviews-link" href={REVIEW_URL} target="_blank" rel="noopener noreferrer">View all on Google</a>
          </div>
        )}
      </header>

      <ul class="reviews-grid">
        {list.map((r, i) => (
          <li class="review-card reveal-card" style={`--reveal-i:${i}`}>
            <header class="review-card-head">
              <div class={`review-avatar${r.profilePhotoUrl ? '' : ' review-avatar--initials'}`}>
                {r.profilePhotoUrl
                  ? <img src={r.profilePhotoUrl} alt="" loading="lazy" referrerpolicy="no-referrer" />
                  : initials(r.author)}
              </div>
              <div class="review-author-meta">
                <span class="review-author">{r.author}</span>
                {r.relativeTime && <span class="review-time">{r.relativeTime}</span>}
              </div>
            </header>
            <span class="review-stars" aria-label={`${r.rating} out of 5 stars`}>{renderStars(r.rating)}</span>
            <p class="review-text">{r.text}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
)}

<style>
  .reviews-section {
    background: var(--bg2);
    padding-top: 96px;
    padding-bottom: 96px;
  }

  .reviews-header {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 48px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }

  .reviews-title {
    font-size: clamp(28px, 3.4vw, 40px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.022em;
    margin: 0;
  }

  .reviews-meta {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px;
    font-size: 14px;
    color: var(--muted);
    margin-top: 4px;
  }

  .reviews-stars {
    color: #ffb547;
    letter-spacing: 2px;
    font-size: 16px;
    line-height: 1;
  }

  .reviews-rating {
    color: var(--text);
    font-weight: 600;
  }

  .reviews-link {
    color: var(--cyan);
    text-decoration: none;
    border-bottom: 1px solid rgba(0, 229, 255, 0.4);
    padding-bottom: 1px;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .reviews-link:hover {
    color: var(--text);
    border-bottom-color: var(--text);
  }

  .reviews-grid {
    list-style: none;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1200px;
  }

  .review-card {
    background: var(--glass);
    border: 1px solid var(--gb);
    border-radius: 16px;
    padding: 24px 22px;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.32);
    display: flex;
    flex-direction: column;
    gap: 14px;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  @media (hover: hover) {
    .review-card:hover {
      border-color: var(--gb2);
      transform: translateY(-2px);
      box-shadow: 0 18px 40px rgba(0, 0, 0, 0.45);
    }
  }

  .review-card-head {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .review-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid var(--gb);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .review-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .review-avatar--initials {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  .review-author-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .review-author {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .review-time {
    font-size: 12px;
    color: var(--dim);
  }

  .review-stars {
    color: #ffb547;
    letter-spacing: 2px;
    font-size: 14px;
    line-height: 1;
  }

  .review-text {
    margin: 0;
    font-size: 14.5px;
    line-height: 1.6;
    color: var(--muted);
    display: -webkit-box;
    -webkit-line-clamp: 8;
    -webkit-box-orient: vertical;
    overflow: hidden;
    white-space: pre-line;
  }

  @media (max-width: 960px) {
    .reviews-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .reviews-section { padding-top: 64px; padding-bottom: 64px; }
    .reviews-grid { grid-template-columns: 1fr; }
  }
</style>
