---
const stats = [
  { value: '$1M → $5M', label: 'Revenue',     accent: 'cyan'   },
  { value: '10x',        label: 'Content',     accent: 'purple' },
  { value: '3.5 yrs',    label: 'Partnership', accent: 'pink'   },
];

const features = [
  'Identify your #1 infrastructure leak',
  'Get a personalized brand reflection',
  'No signup or credit card needed',
];
---

<section class="section testimonial-cta">
  <div class="tc-wrap">
    <!-- Left: testimonial -->
    <div class="tc-panel tc-quote reveal-up">
      <div class="tc-quote-mark" aria-hidden="true">&ldquo;</div>
      <p class="tc-quote-text">
        What started as a videographer role evolved into full ownership of content operations.
        84 pieces of content per month. Produced from four recording sessions.
      </p>
      <div class="tc-attr">
        <img
          src="/images/work/rob-dial.webp"
          alt=""
          class="tc-avatar"
          width="48"
          height="48"
          loading="lazy"
          decoding="async"
        />
        <div class="tc-attr-info">
          <span class="tc-attr-name">Rob Dial</span>
          <span class="tc-attr-role">The Mindset Mentor Podcast</span>
        </div>
      </div>
      <div class="tc-results">
        {stats.map((s, i) => (
          <div class={`tc-result tc-result--${s.accent} reveal-card`} style={`--reveal-i:${i + 1}`}>
            <span class="tc-result-value">{s.value}</span>
            <span class="tc-result-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Right: Brand Mirror CTA -->
    <div class="tc-panel tc-cta reveal-up reveal-delay-1">
      <span class="tc-glow" aria-hidden="true"></span>
      <span class="tc-accent-line" aria-hidden="true"></span>

      <span class="tc-eyebrow">
        <span class="tc-eyebrow-dot"></span>
        BRAND MIRROR
      </span>

      <h2 class="tc-heading">Find Your<br>Bottleneck</h2>

      <p class="tc-sub">
        See where your brand is leaking.<br>
        2 minutes. Free. No email required.
      </p>

      <a href="/brand-mirror" class="tc-btn">
        <span>See Your Reflection</span>
        <svg class="tc-btn-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>

      <ul class="tc-features">
        {features.map((f, i) => (
          <li class="tc-feature reveal-up" style={`transition-delay:${0.18 + i * 0.08}s`}>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M20 6 9 17l-5-5"/>
            </svg>
            <span>{f}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .testimonial-cta {
    padding-left: 0;
    padding-right: 0;
  }

  .tc-wrap {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--bg2);
    border-top: 1px solid var(--gb);
    border-bottom: 1px solid var(--gb);
    overflow: hidden;
  }

  .tc-panel {
    position: relative;
    padding: 56px 56px;
    display: flex;
    flex-direction: column;
  }

  /* Left: testimonial side */
  .tc-quote {
    gap: 28px;
    justify-content: center;
    background: rgba(255, 255, 255, 0.015);
    border-right: 1px solid var(--gb);
  }

  .tc-quote-mark {
    font-family: 'DM Sans', sans-serif;
    font-size: 64px;
    font-weight: 800;
    line-height: 0.5;
    color: var(--cyan);
    height: 28px;
  }

  .tc-quote-text {
    font-size: clamp(17px, 1.6vw, 20px);
    font-weight: 500;
    color: var(--text);
    line-height: 1.55;
  }

  .tc-attr {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .tc-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--purple);
    background: var(--bg3);
    flex-shrink: 0;
  }

  .tc-attr-info { display: flex; flex-direction: column; gap: 2px; }
  .tc-attr-name { font-size: 15px; font-weight: 700; color: var(--text); }
  .tc-attr-role { font-size: 12px; color: var(--muted); }

  .tc-results {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tc-result {
    flex: 1 1 0;
    min-width: 0;
    padding: 12px 16px;
    border-radius: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    transition:
      transform 0.4s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.3s ease,
      box-shadow 0.4s ease;
  }

  .tc-result-value {
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }
  .tc-result-label {
    font-size: 10px;
    font-weight: 500;
    color: var(--dim);
    text-transform: none;
    letter-spacing: 0.02em;
  }

  .tc-result--cyan {
    background: rgba(0, 229, 255, 0.04);
    border: 1px solid rgba(0, 229, 255, 0.18);
  }
  .tc-result--cyan   .tc-result-value { color: var(--cyan); }
  .tc-result--purple {
    background: rgba(123, 97, 255, 0.04);
    border: 1px solid rgba(123, 97, 255, 0.18);
  }
  .tc-result--purple .tc-result-value { color: var(--purple); }
  .tc-result--pink {
    background: rgba(251, 48, 121, 0.04);
    border: 1px solid rgba(251, 48, 121, 0.18);
  }
  .tc-result--pink   .tc-result-value { color: var(--pink); }

  @media (hover: hover) {
    .tc-result:hover { transform: translateY(-2px); }
    .tc-result--cyan:hover   { border-color: rgba(0, 229, 255, 0.38);   box-shadow: 0 8px 22px rgba(0, 229, 255, 0.12); }
    .tc-result--purple:hover { border-color: rgba(123, 97, 255, 0.38);  box-shadow: 0 8px 22px rgba(123, 97, 255, 0.14); }
    .tc-result--pink:hover   { border-color: rgba(251, 48, 121, 0.38);  box-shadow: 0 8px 22px rgba(251, 48, 121, 0.14); }
  }

  /* Right: CTA side */
  .tc-cta {
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 22px;
    background: linear-gradient(180deg, rgba(0, 229, 255, 0.025), rgba(123, 97, 255, 0.035) 55%, transparent);
    isolation: isolate;
  }

  .tc-glow {
    position: absolute;
    top: 10%;
    left: 50%;
    width: 420px;
    height: 320px;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, rgba(0, 229, 255, 0.08) 0%, transparent 70%);
    filter: blur(10px);
    pointer-events: none;
    z-index: -1;
    animation: tc-pulse 8s ease-in-out infinite;
  }

  @keyframes tc-pulse {
    0%, 100% { opacity: 0.7; transform: translateX(-50%) scale(1); }
    50%       { opacity: 1;   transform: translateX(-50%) scale(1.08); }
  }

  .tc-accent-line {
    display: block;
    width: 80px;
    height: 3px;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--cyan), var(--purple));
  }

  .tc-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(251, 48, 121, 0.08);
    border: 1px solid rgba(251, 48, 121, 0.22);
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    color: var(--pink);
  }
  .tc-eyebrow-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--pink);
    box-shadow: 0 0 8px rgba(251, 48, 121, 0.55);
  }

  .tc-heading {
    font-size: clamp(36px, 4.4vw, 48px);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin: 0;
  }

  .tc-sub {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.6;
    max-width: 360px;
    margin: 0;
  }

  .tc-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 16px 36px;
    background: var(--cyan);
    color: var(--bg);
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 6px 24px rgba(0, 229, 255, 0.22);
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.3s ease, filter 0.2s ease;
  }
  .tc-btn-arrow { transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1); }
  @media (hover: hover) {
    .tc-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 32px rgba(0, 229, 255, 0.36);
      filter: brightness(1.06);
      color: var(--bg);
    }
    .tc-btn:hover .tc-btn-arrow { transform: translateX(4px); }
  }

  .tc-features {
    list-style: none;
    margin: 4px 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-start;
  }
  .tc-feature {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--muted);
    font-size: 13px;
    font-weight: 500;
  }
  .tc-feature svg { color: var(--cyan); flex-shrink: 0; }

  /* Responsive */
  @media (max-width: 900px) {
    .tc-wrap { grid-template-columns: 1fr; }
    .tc-quote { border-right: none; border-bottom: 1px solid var(--gb); }
    .tc-panel { padding: 44px 28px; }
    .tc-heading { font-size: 36px; }
  }
  @media (max-width: 480px) {
    .tc-panel { padding: 36px 20px; }
    .tc-results { gap: 8px; }
    .tc-result { padding: 10px 8px; }
    .tc-result-value { font-size: 14px; }
    .tc-btn { padding: 14px 24px; width: 100%; justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tc-glow, .tc-btn, .tc-btn-arrow, .tc-result { animation: none !important; transition: none !important; }
  }
</style>
