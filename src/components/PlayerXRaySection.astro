---
// Canonical Player X-Ray CTA section. Used as the bottom-of-page CTA
// across the site. Routes to /assessment.
---

<section id="player-xray" class="pxr-section">
  <div class="pxr-inner">
    <span class="pxr-eyebrow">Player X-Ray</span>
    <h2 class="pxr-headline">The right infrastructure starts with knowing what kind of player you are.</h2>
    <p class="pxr-sub">
      Take the X-Ray. Five questions. Free. Walk away knowing exactly where you are and the right level to start building from.
    </p>

    <ul class="pxr-pills" aria-label="What you get">
      <li class="pxr-pill"><span class="pxr-pill-dot" aria-hidden="true"></span>Free</li>
      <li class="pxr-pill"><span class="pxr-pill-dot" aria-hidden="true"></span>5 questions</li>
      <li class="pxr-pill"><span class="pxr-pill-dot" aria-hidden="true"></span>Long-term clarity</li>
    </ul>

    <a href="/assessment" class="pxr-cta">
      Take the X-Ray
      <svg class="pxr-cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </a>
  </div>
</section>

<style>
  .pxr-section {
    padding: 96px 24px 96px;
    text-align: center;
  }
  .pxr-inner {
    max-width: 760px;
    margin: 0 auto;
  }
  .pxr-eyebrow {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cyan);
    margin-bottom: 18px;
  }
  .pxr-headline {
    margin: 0 0 14px;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--text);
  }
  .pxr-sub {
    color: var(--muted);
    max-width: 560px;
    margin: 0 auto 28px;
    font-size: clamp(14.5px, 1.5vw, 16px);
    line-height: 1.6;
  }

  /* Pills */
  .pxr-pills {
    list-style: none;
    margin: 0 auto 32px;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 10px;
  }
  .pxr-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    background: rgba(0, 229, 255, 0.06);
    border: 1px solid rgba(0, 229, 255, 0.22);
    border-radius: 100px;
    font-size: 12.5px;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--text);
  }
  .pxr-pill-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--cyan);
    box-shadow: 0 0 8px rgba(0, 229, 255, 0.55);
  }

  /* Take the X-Ray button */
  .pxr-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    background: linear-gradient(135deg, #00E5FF 0%, #7B61FF 100%);
    color: #07090F;
    border-radius: 10px;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.005em;
    text-decoration: none;
    box-shadow: 0 6px 28px rgba(0, 229, 255, 0.25);
    transition: box-shadow 0.3s ease, transform 0.1s ease, filter 0.2s ease;
    -webkit-tap-highlight-color: transparent;
  }
  .pxr-cta:hover {
    filter: brightness(1.06);
    box-shadow: 0 10px 36px rgba(123, 97, 255, 0.34);
  }
  .pxr-cta:active { transform: scale(0.985); }
  .pxr-cta-arrow {
    transition: transform 0.25s ease;
    flex-shrink: 0;
  }
  .pxr-cta:hover .pxr-cta-arrow { transform: translateX(3px); }

  @media (max-width: 640px) {
    .pxr-section { padding: 64px 18px 64px; }
    .pxr-cta { width: 100%; max-width: 360px; justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pxr-cta,
    .pxr-cta-arrow { transition: none; }
  }
</style>
